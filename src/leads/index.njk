<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leads Dashboard — Capital Wealth</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #0f1419 0%, #1a2332 100%);
            color: #e8e8e8;
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
            padding: 30px 20px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            border: 1px solid rgba(201, 169, 110, 0.2);
        }

        .header h1 {
            color: #c9a96e;
            font-size: 32px;
            margin-bottom: 10px;
        }

        .header .stats {
            font-size: 18px;
            color: #a0a0a0;
            margin-top: 10px;
        }

        .login-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(15, 20, 25, 0.98);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .login-box {
            background: #1a2332;
            padding: 40px;
            border-radius: 12px;
            border: 1px solid rgba(201, 169, 110, 0.3);
            max-width: 400px;
            width: 100%;
        }

        .login-box h2 {
            color: #c9a96e;
            margin-bottom: 20px;
            text-align: center;
        }

        .login-box input {
            width: 100%;
            padding: 12px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            color: #e8e8e8;
            font-size: 16px;
            margin-bottom: 15px;
        }

        .login-box button {
            width: 100%;
            padding: 12px;
            background: #c9a96e;
            color: #0f1419;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
        }

        .login-box button:hover {
            background: #d4b77e;
        }

        .error {
            color: #ff6b6b;
            text-align: center;
            margin-top: 10px;
            font-size: 14px;
        }

        .table-container {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(201, 169, 110, 0.2);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: rgba(201, 169, 110, 0.1);
            color: #c9a96e;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            padding: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: #e8e8e8;
        }

        tr:hover {
            background: rgba(255, 255, 255, 0.02);
            cursor: pointer;
        }

        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .badge-new {
            background: rgba(255, 149, 0, 0.2);
            color: #ff9500;
            border: 1px solid rgba(255, 149, 0, 0.4);
        }

        .badge-contacted {
            background: rgba(52, 152, 219, 0.2);
            color: #3498db;
            border: 1px solid rgba(52, 152, 219, 0.4);
        }

        .badge-converted {
            background: rgba(46, 204, 113, 0.2);
            color: #2ecc71;
            border: 1px solid rgba(46, 204, 113, 0.4);
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            align-items: center;
            justify-content: center;
            z-index: 999;
            padding: 20px;
            overflow-y: auto;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #1a2332;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid rgba(201, 169, 110, 0.3);
            max-width: 700px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            margin: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .modal-header h2 {
            color: #c9a96e;
            font-size: 24px;
        }

        .close-modal {
            background: none;
            border: none;
            color: #a0a0a0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .close-modal:hover {
            color: #e8e8e8;
        }

        .detail-group {
            margin-bottom: 20px;
        }

        .detail-label {
            color: #a0a0a0;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
            font-weight: 600;
        }

        .detail-value {
            color: #e8e8e8;
            font-size: 16px;
            word-break: break-word;
        }

        .detail-section {
            background: rgba(255, 255, 255, 0.03);
            padding: 15px;
            border-radius: 8px;
            margin-top: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .detail-section h3 {
            color: #c9a96e;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 15px;
        }

        .loading {
            text-align: center;
            padding: 40px;
            color: #a0a0a0;
            font-size: 18px;
        }

        @media (max-width: 768px) {
            .table-container {
                display: none;
            }

            .cards-container {
                display: block;
            }

            .lead-card {
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(201, 169, 110, 0.2);
                border-radius: 12px;
                padding: 20px;
                margin-bottom: 15px;
                cursor: pointer;
            }

            .lead-card:hover {
                background: rgba(255, 255, 255, 0.05);
            }

            .lead-card-header {
                display: flex;
                justify-content: space-between;
                align-items: start;
                margin-bottom: 15px;
            }

            .lead-card-name {
                font-size: 18px;
                font-weight: 600;
                color: #c9a96e;
                margin-bottom: 5px;
            }

            .lead-card-date {
                font-size: 14px;
                color: #a0a0a0;
            }

            .lead-card-info {
                font-size: 14px;
                color: #e8e8e8;
                margin-bottom: 8px;
            }

            .lead-card-label {
                color: #a0a0a0;
                margin-right: 5px;
            }
        }

        @media (min-width: 769px) {
            .cards-container {
                display: none;
            }
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #a0a0a0;
        }

        .empty-state h3 {
            color: #c9a96e;
            font-size: 24px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div id="login-overlay" class="login-overlay">
        <div class="login-box">
            <h2>Leads Dashboard</h2>
            <input type="password" id="password-input" placeholder="Enter password" autocomplete="off">
            <button onclick="login()">Access Dashboard</button>
            <div id="login-error" class="error"></div>
        </div>
    </div>

    <div id="dashboard" style="display: none;">
        <div class="container">
            <div class="header">
                <h1>Leads Dashboard</h1>
                <div class="stats">Total Leads: <strong id="total-leads">0</strong></div>
            </div>

            <div id="loading" class="loading">Loading leads...</div>

            <div id="table-container" class="table-container" style="display: none;">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Savings</th>
                            <th>Timeline</th>
                            <th>Source</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="leads-table-body"></tbody>
                </table>
            </div>

            <div id="cards-container" class="cards-container"></div>

            <div id="empty-state" class="empty-state" style="display: none;">
                <h3>No leads yet</h3>
                <p>Leads will appear here when visitors submit the contact form.</p>
            </div>
        </div>
    </div>

    <div id="modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Lead Details</h2>
                <button class="close-modal" onclick="closeModal()">&times;</button>
            </div>
            <div id="modal-body"></div>
        </div>
    </div>

    <script>
        let currentPassword = sessionStorage.getItem('cwa_dashboard_key');
        let leadsData = [];

        if (currentPassword) {
            document.getElementById('login-overlay').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            loadLeads();
        }

        document.getElementById('password-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') login();
        });

        async function login() {
            const password = document.getElementById('password-input').value;
            const errorEl = document.getElementById('login-error');

            try {
                const response = await fetch(`/api/leads?key=${encodeURIComponent(password)}`);
                if (response.ok) {
                    sessionStorage.setItem('cwa_dashboard_key', password);
                    currentPassword = password;
                    document.getElementById('login-overlay').style.display = 'none';
                    document.getElementById('dashboard').style.display = 'block';
                    loadLeads();
                } else {
                    errorEl.textContent = 'Invalid password';
                }
            } catch (err) {
                errorEl.textContent = 'Connection error';
            }
        }

        async function loadLeads() {
            try {
                const response = await fetch(`/api/leads?key=${encodeURIComponent(currentPassword)}`);
                if (!response.ok) {
                    throw new Error('Failed to load leads');
                }

                leadsData = await response.json();
                document.getElementById('loading').style.display = 'none';

                if (leadsData.length === 0) {
                    document.getElementById('empty-state').style.display = 'block';
                    return;
                }

                document.getElementById('total-leads').textContent = leadsData.length;
                renderTable();
                renderCards();
            } catch (err) {
                document.getElementById('loading').innerHTML = '<div style="color: #ff6b6b;">Failed to load leads</div>';
            }
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
                hour: 'numeric',
                minute: '2-digit'
            });
        }

        function getStatusBadge(status) {
            const statusMap = {
                'new': 'badge-new',
                'contacted': 'badge-contacted',
                'converted': 'badge-converted'
            };
            return `<span class="badge ${statusMap[status] || 'badge-new'}">${status || 'new'}</span>`;
        }

        function getSource(lead) {
            if (lead.utm_source) return lead.utm_source;
            if (lead.referrer) {
                try {
                    return new URL(lead.referrer).hostname;
                } catch (e) {
                    return 'Direct';
                }
            }
            return 'Direct';
        }

        function renderTable() {
            const tbody = document.getElementById('leads-table-body');
            tbody.innerHTML = leadsData.map((lead, index) => `
                <tr onclick="showModal(${index})">
                    <td>${formatDate(lead.created_at)}</td>
                    <td><strong>${lead.name}</strong></td>
                    <td>${lead.email}</td>
                    <td>${lead.phone}</td>
                    <td>${lead.savings || '—'}</td>
                    <td>${lead.retirement_timeline || '—'}</td>
                    <td>${getSource(lead)}</td>
                    <td>${getStatusBadge(lead.status)}</td>
                </tr>
            `).join('');
            document.getElementById('table-container').style.display = 'block';
        }

        function renderCards() {
            const container = document.getElementById('cards-container');
            container.innerHTML = leadsData.map((lead, index) => `
                <div class="lead-card" onclick="showModal(${index})">
                    <div class="lead-card-header">
                        <div>
                            <div class="lead-card-name">${lead.name}</div>
                            <div class="lead-card-date">${formatDate(lead.created_at)}</div>
                        </div>
                        ${getStatusBadge(lead.status)}
                    </div>
                    <div class="lead-card-info">
                        <span class="lead-card-label">Email:</span> ${lead.email}
                    </div>
                    <div class="lead-card-info">
                        <span class="lead-card-label">Phone:</span> ${lead.phone}
                    </div>
                    <div class="lead-card-info">
                        <span class="lead-card-label">Savings:</span> ${lead.savings || 'Not specified'}
                    </div>
                    <div class="lead-card-info">
                        <span class="lead-card-label">Source:</span> ${getSource(lead)}
                    </div>
                </div>
            `).join('');
        }

        function showModal(index) {
            const lead = leadsData[index];
            const modal = document.getElementById('modal');
            const modalBody = document.getElementById('modal-body');

            modalBody.innerHTML = `
                <div class="detail-group">
                    <div class="detail-label">Name</div>
                    <div class="detail-value">${lead.name}</div>
                </div>
                <div class="detail-group">
                    <div class="detail-label">Email</div>
                    <div class="detail-value"><a href="mailto:${lead.email}" style="color: #c9a96e;">${lead.email}</a></div>
                </div>
                <div class="detail-group">
                    <div class="detail-label">Phone</div>
                    <div class="detail-value"><a href="tel:${lead.phone}" style="color: #c9a96e;">${lead.phone}</a></div>
                </div>
                <div class="detail-group">
                    <div class="detail-label">Retirement Savings</div>
                    <div class="detail-value">${lead.savings || 'Not specified'}</div>
                </div>
                <div class="detail-group">
                    <div class="detail-label">Timeline</div>
                    <div class="detail-value">${lead.retirement_timeline || 'Not specified'}</div>
                </div>
                <div class="detail-group">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">${getStatusBadge(lead.status)}</div>
                </div>
                <div class="detail-group">
                    <div class="detail-label">Submitted</div>
                    <div class="detail-value">${formatDate(lead.created_at)}</div>
                </div>
                ${lead.message ? `
                <div class="detail-group">
                    <div class="detail-label">Message</div>
                    <div class="detail-value">${lead.message}</div>
                </div>
                ` : ''}

                <div class="detail-section">
                    <h3>Lead Source</h3>
                    ${lead.utm_source ? `
                    <div class="detail-group">
                        <div class="detail-label">UTM Source</div>
                        <div class="detail-value">${lead.utm_source}</div>
                    </div>
                    ` : ''}
                    ${lead.utm_medium ? `
                    <div class="detail-group">
                        <div class="detail-label">UTM Medium</div>
                        <div class="detail-value">${lead.utm_medium}</div>
                    </div>
                    ` : ''}
                    ${lead.utm_campaign ? `
                    <div class="detail-group">
                        <div class="detail-label">UTM Campaign</div>
                        <div class="detail-value">${lead.utm_campaign}</div>
                    </div>
                    ` : ''}
                    ${lead.utm_content ? `
                    <div class="detail-group">
                        <div class="detail-label">UTM Content</div>
                        <div class="detail-value">${lead.utm_content}</div>
                    </div>
                    ` : ''}
                    ${lead.utm_term ? `
                    <div class="detail-group">
                        <div class="detail-label">UTM Term</div>
                        <div class="detail-value">${lead.utm_term}</div>
                    </div>
                    ` : ''}
                    ${lead.referrer ? `
                    <div class="detail-group">
                        <div class="detail-label">Referrer</div>
                        <div class="detail-value">${lead.referrer}</div>
                    </div>
                    ` : ''}
                    ${lead.landing_page ? `
                    <div class="detail-group">
                        <div class="detail-label">Landing Page</div>
                        <div class="detail-value"><a href="${lead.landing_page}" style="color: #c9a96e;" target="_blank">${lead.landing_page}</a></div>
                    </div>
                    ` : ''}
                    ${lead.submitted_from ? `
                    <div class="detail-group">
                        <div class="detail-label">Submitted From</div>
                        <div class="detail-value">${lead.submitted_from}</div>
                    </div>
                    ` : ''}
                    ${!lead.utm_source && !lead.referrer ? `
                    <div class="detail-value" style="color: #a0a0a0;">Direct traffic (no tracking data)</div>
                    ` : ''}
                </div>
            `;

            modal.classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }

        // Close modal on background click
        document.getElementById('modal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>
