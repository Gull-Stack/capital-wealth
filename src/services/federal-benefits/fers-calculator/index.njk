<script>
function calculateFERS() {
  const yearsService = parseFloat(document.getElementById('yearsService').value) || 0;
  const high3Salary = parseFloat(document.getElementById('high3Salary').value) || 0;
  const retirementAge = parseInt(document.getElementById('retirementAge').value) || 0;
  const survivorBenefit = document.getElementById('survivorBenefit').value;
  
  if (yearsService === 0 || high3Salary === 0 || retirementAge === 0) {
    alert('Please fill in all required fields.');
    return;
  }
  
  // Determine multiplier
  let multiplier = 0.01; // Standard 1%
  
  // Enhanced 1.1% multiplier for age 62+ with 20+ years
  if (retirementAge >= 62 && yearsService >= 20) {
    multiplier = 0.011;
  }
  
  // Calculate base annuity
  let annualAnnuity = yearsService * high3Salary * multiplier;
  
  // Apply survivor benefit reduction
  let survReduction = 0;
  if (survivorBenefit === 'partial') {
    survReduction = 0.05;
  } else if (survivorBenefit === 'full') {
    survReduction = 0.10;
  }
  
  annualAnnuity = annualAnnuity * (1 - survReduction);
  
  const monthlyAnnuity = annualAnnuity / 12;
  
  // Display results
  document.getElementById('annualAmount').textContent = '$' + Math.round(annualAnnuity).toLocaleString();
  document.getElementById('monthlyAmount').textContent = '$' + Math.round(monthlyAnnuity).toLocaleString();
  document.getElementById('calculatorResults').style.display = 'block';
  
  // Scroll to results
  document.getElementById('calculatorResults').scrollIntoView({ behavior: 'smooth' });
}

// Allow Enter key to trigger calculation
document.addEventListener('DOMContentLoaded', function() {
  const inputs = document.querySelectorAll('.fed-ed-calc-input');
  inputs.forEach(input => {
    input.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        calculateFERS();
      }
    });
  });
});
</script>