<script>
document.addEventListener('DOMContentLoaded', function() {
  const links = document.querySelectorAll('.ep-sidebar-link');
  const sections = [];
  links.forEach(link => {
    const id = link.getAttribute('href').replace('#', '');
    const section = document.getElementById(id);
    if (section) sections.push({ id, el: section, link });
  });
  
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => l.classList.remove('active'));
        const active = document.querySelector('.ep-sidebar-link[href="#' + entry.target.id + '"]');
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -60% 0px' });
  
  sections.forEach(s => observer.observe(s.el));
});

function calculateFERS() {
  // Get input values
  const high3 = parseFloat(document.getElementById('high3').value) || 0;
  const years = parseFloat(document.getElementById('years').value) || 0;
  const age = parseInt(document.getElementById('age').value) || 0;
  const sickLeave = parseFloat(document.getElementById('sick-leave').value) || 0;
  const hasMilitary = document.getElementById('military').checked;
  const isLawEnforcement = document.getElementById('law-enforcement').checked;
  
  if (high3 <= 0 || years <= 0 || age <= 0) {
    alert('Please enter valid values for High-3 salary, years of service, and retirement age.');
    return;
  }
  
  // Convert sick leave hours to years (2087 hours = 1 year)
  const sickLeaveYears = sickLeave / 2087;
  let totalYears = years + sickLeaveYears;
  
  // Add estimated military buyback time if checked (user should provide actual)
  if (hasMilitary) {
    totalYears += 4; // Estimate - actual calculation needs specific military service
  }
  
  // Determine multiplier
  let multiplier = 0.01; // Standard 1%
  
  if (isLawEnforcement) {
    // Special category: 1.7% for first 20 years, 1% thereafter
    const specialYears = Math.min(totalYears, 20);
    const regularYears = Math.max(0, totalYears - 20);
    multiplier = (specialYears * 0.017 + regularYears * 0.01) / totalYears;
  } else if (age >= 62 && totalYears >= 20) {
    multiplier = 0.011; // Enhanced 1.1%
  }
  
  // Calculate annual annuity
  const annualAmount = Math.round(totalYears * high3 * multiplier);
  const monthlyAmount = Math.round(annualAmount / 12);
  
  // Display results
  document.getElementById('annual-amount').textContent = '$' + annualAmount.toLocaleString();
  document.getElementById('monthly-amount').textContent = '$' + monthlyAmount.toLocaleString() + ' per month';
  
  // FERS supplement note
  let supplementNote = '';
  if (age < 62 && totalYears >= 30 && age >= 56) {
    supplementNote = 'You may be eligible for the FERS supplement until age 62.';
  } else if (age < 62 && totalYears >= 20 && age >= 60) {
    supplementNote = 'You may be eligible for the FERS supplement until age 62.';
  }
  document.getElementById('supplement-note').textContent = supplementNote;
  
  // Show results
  document.getElementById('results').style.display = 'block';
  
  // Scroll to results
  document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// FAQ functionality
document.querySelectorAll('.ep-faq-item').forEach(function(item) {
  item.addEventListener('click', function() {
    const isActive = this.classList.contains('active');
    
    // Close all items
    document.querySelectorAll('.ep-faq-item').forEach(function(el) {
      el.classList.remove('active');
    });
    
    // Open clicked item if it wasn't already open
    if (!isActive) {
      this.classList.add('active');
    }
  });
});
</script>