            </tr>
          </thead>
          <tbody>
            <tr class="highlight">
              <td><strong>MRA + 30 years</strong></td>
              <td>Your MRA (56-57)</td>
              <td>30 years</td>
              <td>Yes - Full supplement</td>
            </tr>
            <tr class="highlight">
              <td><strong>Age 60 + 20 years</strong></td>
              <td>60</td>
              <td>20 years</td>
              <td>Yes - Full supplement</td>
            </tr>
            <tr>
              <td><strong>Age 62 + 5 years</strong></td>
              <td>62</td>
              <td>5 years</td>
              <td>No - Can claim actual SS</td>
            </tr>
            <tr>
              <td><strong>MRA + 10 years</strong></td>
              <td>Your MRA (56-57)</td>
              <td>10-29 years</td>
              <td>No - Reduced pension</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <div class="fed-ed-stats-grid">
