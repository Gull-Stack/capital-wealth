   1. HERO — Asymmetric editorial layout
   ═══════════════════════════════════════════════════════════ #}
<section class="ep-hero" id="overview">
  <div class="ep-hero-inner">
    <div>
      <span class="ep-chapter-label">FERS Retirement</span>
      <h1 class="ep-hero-title">Maximize Your Federal</h1>
      <span class="ep-hero-title-italic">Pension.</span>
      <p class="ep-hero-body">Your FERS pension forms the foundation of your federal retirement. Understanding your annuity calculation, retirement timing, and benefit coordination requires specialized expertise to maximize lifetime value.</p>
      <a href="/contact/" class="ep-btn-primary">Begin FERS Analysis</a>
    </div>
    <div class="ep-hero-image-wrap">
      <img src="/assets/images/photos/federal/capitalwealth-federal-us-capitol-dome.jpg"
           alt="US Capitol dome representing FERS retirement foundation"
           class="ep-hero-image">
      <div class="ep-pull-quote">
        <p>"Your FERS pension could be worth nearly $1 million over your retirement."</p>
        <cite>Mike Stevens, IAR</cite>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   2. KEY FACTS — Technical precision row
   ═══════════════════════════════════════════════════════════ #}
<section class="ep-facts">
  <div class="ep-facts-inner">
    <div class="ep-fact">
      <div class="ep-fact-label">FERS Formula</div>
      <div class="ep-fact-value">Service × High-3 × Multiplier</div>
    </div>
    <div class="ep-fact">
      <div class="ep-fact-label">Standard Multiplier</div>
      <div class="ep-fact-value">1.0% (1.1% enhanced)</div>
    </div>
    <div class="ep-fact">
      <div class="ep-fact-label">MRA + 30 Years</div>
