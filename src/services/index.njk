<script>
(function() {
  document.querySelectorAll('.svc-accordion-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = this.closest('.svc-accordion-item');
      var isOpen = item.classList.contains('active');
      // Close all
      document.querySelectorAll('.svc-accordion-item').forEach(function(el) {
        el.classList.remove('active');
        el.querySelector('.svc-accordion-trigger').setAttribute('aria-expanded', 'false');
      });
      // Toggle clicked
      if (!isOpen) {
        item.classList.add('active');
        this.setAttribute('aria-expanded', 'true');
      }
    });
  });
})();
</script>
