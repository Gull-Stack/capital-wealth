}

.ep-sub-feature:hover h4 {
  color: var(--secondary);
}

.ep-sub-feature p {
  font-size: 0.875rem;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

/* Process — liquid glass cards with image */
.ep-process {
  padding: 6rem 2rem;
  background: var(--surface);
  position: relative;
  overflow: hidden;
}

.ep-process-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.ep-process-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  margin-bottom: 3rem;
}

.ep-process-title {
  font-family: var(--font-serif-display);
  font-size: clamp(2rem, 3.5vw, 2.8rem);
