  font-weight: 400;
  color: var(--primary);
  margin-bottom: 1rem;
}

.ep-faq-sub {
  font-size: 0.95rem;
  color: var(--on-surface-variant);
  line-height: 1.6;
  margin-bottom: 2rem;
}

.ep-faq-item {
  display: block;
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  border-bottom: 1px solid rgba(194, 198, 210, 0.2);
  padding: 0;
  cursor: pointer;
  font-family: inherit;
}

.ep-faq-q {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.25rem 0;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  color: var(--on-surface);
}

.ep-faq-icon {
  font-size: 1.5rem;
  color: var(--secondary);
  transition: transform 0.2s ease;
  flex-shrink: 0;
  margin-left: 1rem;
}

.ep-faq-item.active .ep-faq-icon {
  transform: rotate(45deg);
}

.ep-faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.ep-faq-item.active .ep-faq-a {
  max-height: 300px;
}

.ep-faq-a p {
  padding: 0 0 1.5rem;
  font-size: 0.925rem;
  line-height: 1.7;
  color: var(--on-surface-variant);
}

/* Related Services */
.ep-related {
  padding: 4rem 2rem;
  background: var(--surface);
  border-top: 1px solid rgba(194, 198, 210, 0.15);
}

.ep-related-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.ep-related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 2rem;
}

.ep-related-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 2rem;
  text-decoration: none;
  background: var(--surface-container-low);
  transition: all 0.2s ease;
}

.ep-related-link:hover {
  background: white;
}

.ep-related-link:not(:last-child) {
  border-right: 1px solid rgba(194, 198, 210, 0.15);
}

.ep-related-name {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  color: var(--on-surface);
}

.ep-related-arrow {
  font-size: 1.25rem;
  color: var(--secondary);
}

/* CTA — matches homepage final-cta */
.ep-cta {
  padding: 4rem 2rem;
  background: var(--surface);
}

.ep-cta-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.ep-cta-content {
  max-width: 520px;
}

.ep-cta-title {
  font-family: var(--font-serif-display);
  font-size: clamp(2.2rem, 4vw, 3rem);
  font-style: italic;
  font-weight: 400;
  color: var(--primary);
  margin-bottom: 1.5rem;
}

.ep-cta-body {
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--on-surface-variant);
  margin-bottom: 2rem;
}

.ep-cta-image {
  width: 100%;
  height: 400px;
  object-fit: cover;
  border-radius: 16px;
}

.ep-cta-promise {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--on-surface-variant);
  margin-top: 1.5rem;
}

/* Responsive */
@media (max-width: 768px) {
  .ep-hero-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .ep-hero {
    padding: 4rem 1.5rem 3rem;
  }

  .ep-pull-quote {
    position: relative;
    bottom: auto;
    left: auto;
    margin-top: -2rem;
    max-width: 100%;
  }

  .ep-facts-inner {
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .ep-fact {
    flex: 0 0 calc(50% - 0.75rem);
  }

  .ep-framework-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .ep-framework-grid {
    grid-template-columns: 1fr;
  }

  .ep-framework {
    padding: 4rem 1.5rem;
  }

  .ep-dark {
    padding: 4rem 1.5rem;
  }

  .ep-dark-grid {
    grid-template-columns: 1fr;
  }

  .ep-glass-card {
    padding: 2rem;
    min-height: auto;
  }

  .ep-glass-card:last-child {
    margin-top: 0;
  }

  .ep-transfer {
    padding: 4rem 1.5rem;
  }

  .ep-transfer-inner {
    flex-direction: column;
    gap: 2.5rem;
  }

  .ep-transfer-image-wrap {
    flex: none;
    width: 100%;
  }

  .ep-transfer-image {
    height: 350px;
  }

  .ep-transfer-image-accent {
    display: none;
  }

  .ep-process {
    padding: 4rem 1.5rem;
  }

  .ep-process-header {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .ep-process-image {
    height: 220px;
  }

  .ep-steps-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .ep-faq-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .ep-faq {
    padding: 4rem 1.5rem;
  }

  .ep-related-grid {
    grid-template-columns: 1fr;
  }

  .ep-related-link:not(:last-child) {
    border-right: none;
    border-bottom: 1px solid rgba(194, 198, 210, 0.15);
  }

  .ep-cta {
    padding: 3rem 1.5rem;
  }

  .ep-cta-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .ep-cta-image {
    height: 250px;
  }

  .ep-btn-primary, .ep-btn-ghost {
    text-align: center;
  }
}
</style>

{# ═══════════════════════════════════════════════════════════
   1. HERO — Asymmetric editorial layout
   ═══════════════════════════════════════════════════════════ #}
<section class="ep-hero">
  <div class="ep-hero-inner">
    <div>
      <span class="ep-chapter-label">Portfolio Management</span>
      <h1 class="ep-hero-title">Invested for Income,<br>Not Just Growth.</h1>
      <span class="ep-hero-title-italic">Strategic Wealth Management.</span>
      <p class="ep-hero-body">Retirement portfolios have different goals than accumulation portfolios. Yours should be designed to generate reliable income, manage volatility, and preserve your purchasing power for decades.</p>
      <a href="/contact/" class="ep-btn-primary">Start Your Portfolio Review</a>
    </div>
    <div class="ep-hero-image-wrap">
      <img src="/assets/images/photos/retirement/capitalwealth-retirement-couple-beach.jpg"
           alt="Couple enjoying retirement at the beach"
           class="ep-hero-image">
      <div class="ep-pull-quote">
        <p>"A portfolio without a purpose is just a collection of accounts."</p>
        <cite>Mike Stevens, IAR</cite>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   2. KEY FACTS — Technical precision row
   ═══════════════════════════════════════════════════════════ #}
<section class="ep-facts">
  <div class="ep-facts-inner">
    <div class="ep-fact">
      <div class="ep-fact-label">Strategy</div>
