}

.ep-step-card p {
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--on-surface-variant);
}

/* FAQ */
.ep-faq {
  padding: 6rem 2rem;
  background: var(--surface-container-low);
}

.ep-faq-inner {
