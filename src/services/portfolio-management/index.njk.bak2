  margin-left: 0.25rem;
}

.ep-glass-body {
  font-size: 0.95rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 2rem;
}

.ep-check-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.ep-check-list li {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: white;
  font-family: var(--font-mono);
