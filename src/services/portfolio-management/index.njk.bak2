  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.75rem 0;
}

.ep-check-list li::before {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--secondary);
  flex-shrink: 0;
}

/* Asymmetric Image + Text */
.ep-transfer {
  padding: 6rem 2rem;
  background: var(--surface-container-low);
}

.ep-transfer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
