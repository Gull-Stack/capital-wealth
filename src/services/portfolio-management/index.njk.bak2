  color: var(--on-surface-variant);
}

/* Dark Section — Stats & Solution */
.ep-dark {
  padding: 6rem 2rem;
  background: var(--primary);
  position: relative;
  overflow: hidden;
}

.ep-dark::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0, 56, 112, 1) 0%, rgba(25, 79, 144, 0.8) 100%);
  z-index: 0;
}

.ep-dark-inner {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.ep-dark-header {
  margin-bottom: 4rem;
}

.ep-dark-title {
  font-family: var(--font-serif-display);
  font-size: clamp(2.2rem, 4vw, 3rem);
  font-weight: 400;
  color: white;
  line-height: 1.15;
}

.ep-dark-title em {
  font-weight: 300;
  opacity: 0.8;
}

.ep-dark-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: stretch;
}

.ep-glass-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 3rem;
  min-height: 420px;
  display: flex;
  flex-direction: column;
}

.ep-glass-card:last-child {
