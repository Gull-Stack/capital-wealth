      <p class="ep-cta-body">Every retirement plan is different. Schedule a complimentary visit to review your current options, analyze whether an SDBA adds value, and see how professional management can optimize your workplace retirement plan.</p>
      <a href="/contact/" class="ep-btn-primary">Schedule Your Visit</a>
      <p class="ep-cta-promise">A Fiduciary Promise</p>
    </div>
    <img src="/assets/images/photos/sdba/couple-retirement-sunset-fields.jpg" alt="Couple celebrating a well-planned retirement after professional SDBA management" class="ep-cta-image" loading="lazy" width="1600" height="1066">
  </div>
</section>

<!-- Chart.js for SDBA Advantage Calculator -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
<script>
(function() {
  function parseCurrency(val) {
    if (val === null || val === undefined) return 0;
    var cleaned = String(val).replace(/[^0-9.]/g, '');
    var n = parseFloat(cleaned);
    return isFinite(n) ? Math.max(0, Math.round(n)) : 0;
  }
  function fmtCurrency(n) { return '$' + Math.round(n).toLocaleString('en-US'); }

  var ageEl, salaryEl, balanceEl, retireEl, headlineEl, runBtn, canvas, chart;

  function setupCurrency(el) {
    el.addEventListener('blur', function() {
      var v = parseCurrency(el.value);
      el.value = v ? fmtCurrency(v) : '';
    });
    el.addEventListener('focus', function() {
      el.value = String(parseCurrency(el.value) || '');
    });
  }

  function project(balance, ages, salary, rate) {
    var contributionRate = 0.078 + 0.046; // 12.4%
    var salaryGrowth = 0.03;
    var monthlyRate = Math.pow(1 + rate, 1 / 12);
    var monthlyFactor = Math.pow(monthlyRate, 12);
    var contribMultiplier = (monthlyFactor - 1) / (monthlyRate - 1);
    var total = balance;
    var out = [balance];
    for (var i = 0; i < ages.length - 1; i++) {
      var yrs = i;
      var thisYearSalary = salary * Math.pow(1 + salaryGrowth, yrs);
      var thisYearContrib = thisYearSalary * contributionRate;
      total = total * monthlyFactor + (thisYearContrib / 12) * contribMultiplier;
      out.push(Math.round(Math.max(0, total)));
    }
    return out;
  }

  function renderChart(ages, withSdba, defaultPlan) {
    if (!window.Chart) {
      var t = setInterval(function() {
        if (window.Chart) { clearInterval(t); renderChart(ages, withSdba, defaultPlan); }
      }, 150);
      return;
    }
    if (chart) chart.destroy();
    chart = new Chart(canvas.getContext('2d'), {
      type: 'line',
      data: {
        labels: ages,
        datasets: [
          { label: 'Advised SDBA (+1%)', data: withSdba, borderColor: '#C7A356',
            backgroundColor: 'rgba(199,163,86,0.12)', borderWidth: 3, pointRadius: 0, tension: 0.25, fill: true },
          { label: 'Default 401k (S&P 500, 7%)', data: defaultPlan, borderColor: '#16253C',
            backgroundColor: 'rgba(22,37,60,0.04)', borderWidth: 3, pointRadius: 0, tension: 0.25, fill: true }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'bottom', labels: { color: '#16253C', boxWidth: 16, boxHeight: 10, padding: 14, font: { size: 12, weight: '600' } } },
          tooltip: {
            callbacks: {
              title: function(items) { return 'Age ' + items[0].label; },
              label: function(ctx) { return ctx.dataset.label + ': ' + fmtCurrency(ctx.parsed.y); }
            }
          }
        },
        scales: {
          y: { ticks: { callback: function(v) {
            if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
            if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
            return '$' + v;
          }, color: '#64748b' }, grid: { color: 'rgba(22,37,60,0.08)' } },
          x: { ticks: { color: '#64748b', maxTicksLimit: 8 }, grid: { display: false } }
        }
      }
    });
  }

  function run() {
    var age = parseInt(ageEl.value, 10) || 0;
    var retire = parseInt(retireEl.value, 10) || 65;
    if (retire < 50) retire = 50;
    if (retire > 80) retire = 80;
    var salary = parseCurrency(salaryEl.value);
    var balance = parseCurrency(balanceEl.value);

    if (!age || age < 18 || age >= retire || salary <= 0) {
      headlineEl.innerHTML = 'Enter your details to see your SDBA advantage.';
      if (chart) { chart.destroy(); chart = null; }
      return;
    }

    var years = retire - age;
    var ages = [];
    for (var i = 0; i <= years; i++) ages.push(age + i);

    var defaultPlan = project(balance, ages, salary, 0.07);
    var withSdba = project(balance, ages, salary, 0.08);
    var diff = withSdba[withSdba.length - 1] - defaultPlan[defaultPlan.length - 1];
    headlineEl.innerHTML = 'Could <span class="ep-calc-highlight">' + fmtCurrency(diff) + '</span> more change your retirement?';
    renderChart(ages, withSdba, defaultPlan);
  }

  function init() {
    ageEl = document.getElementById('sdba-calc-age');
    salaryEl = document.getElementById('sdba-calc-salary');
    balanceEl = document.getElementById('sdba-calc-balance');
    retireEl = document.getElementById('sdba-calc-retire');
    headlineEl = document.getElementById('sdba-calc-headline');
    runBtn = document.getElementById('sdba-calc-run');
    canvas = document.getElementById('sdba-calc-chart');
    if (!canvas) return;

    setupCurrency(salaryEl);
    setupCurrency(balanceEl);
    runBtn.addEventListener('click', run);
    [ageEl, salaryEl, balanceEl, retireEl].forEach(function(el) {
      el.addEventListener('change', run);
      el.addEventListener('keyup', function(e) { if (e.key === 'Enter') run(); });
    });
    setTimeout(run, 250);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>