            <script>
            document.getElementById('workshop-form').addEventListener('submit', async function(e) {
                e.preventDefault();
                var btn = document.getElementById('workshop-submit-btn');
                var status = document.getElementById('workshop-form-status');
                if (this.querySelector('[name="website"]').value) return;
                btn.disabled = true;
                btn.innerHTML = 'REGISTERING...';
                status.textContent = '';
                try {
                    var fullName = document.getElementById('first_name').value + ' ' + document.getElementById('last_name').value;
                    var res = await fetch('/api/submit-lead', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            name: fullName,
                            email: document.getElementById('email').value,
                            phone: document.getElementById('phone').value,
                            savings: document.getElementById('years_service').value ? document.getElementById('years_service').value + ' years service' : '',
                            retirementTimeline: document.getElementById('retirement_timeline').value,
                            questions: 'WORKSHOP REGISTRATION — April 9, 2026. Agency: ' + (document.getElementById('agency').value || 'Not specified') + '. Spouse: ' + document.getElementById('spouse').value,
                            submitted_from: '/federal-workshop-april-9/',
                            utm_source: 'workshop',
                            utm_medium: 'landing_page',
                            utm_campaign: 'federal_workshop_april_2026'
                        })
                    });
                    var data = await res.json();
                    if (res.ok) {
                        if (typeof gtag === 'function') {
                            gtag('event', 'generate_lead', { event_category: 'conversion', event_label: 'workshop_registration', value: 1 });
                        }
                        window.location.href = '/thank-you/';
                    } else {
                        status.style.color = '#c0392b';
                        status.textContent = data.error || 'Something went wrong. Please call 801.210.2800.';
                    }
                } catch (err) {
                    status.style.color = '#c0392b';
                    status.textContent = 'Network error. Please call 801.210.2800.';
                }
                btn.disabled = false;
                btn.innerHTML = 'RESERVE MY SEAT <span>→</span>';
            });
            </script>

            <p class="contact-form-disclaimer">By registering, you agree to be contacted by Capital Wealth regarding the workshop. Your information is kept confidential.</p>
        </div>
    </div>
