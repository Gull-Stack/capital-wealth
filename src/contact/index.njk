---
layout: layouts/base.njk
title: "Contact Capital Wealth Advisors | Schedule Consultation | Lehi, UT"
description: "Schedule a consultation with Capital Wealth Advisors in Lehi, Utah. Call 801.210.2800 or email info@capitalwealth.com. Initial consultations are complimentary."
breadcrumbs:
  - { name: "Home", url: "/" }
  - { name: "Contact", url: "/contact/" }
---

<section class="titan-hero">
    <div class="titan-hero-inner" style="grid-template-columns: 1fr;">
        <div style="max-width: 700px;">
            <p class="titan-section-label">GET IN TOUCH</p>
            <h1 class="titan-hero-h1">Let's Talk About Your Retirement</h1>
            <p class="titan-hero-body">No pressure. No pitch. Just a conversation about your goals and whether we're the right fit. Initial consultations are complimentary for qualified families.</p>
        </div>
    </div>
</section>

{# Two-column: Form Left, Details Right #}
<section style="background: #f0f1f3; padding: 5rem 2rem;">
    <div class="titan-fundamentals-inner">
        <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: start;">

            {# Contact Form #}
            <div style="background: #fff; border-radius: 12px; padding: 2.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
                <h2 style="font-family: var(--font-family); font-size: 1.6rem; font-weight: 600; color: var(--navy); margin-bottom: 1rem;">Request a Consultation</h2>
                <p style="color: rgba(25,79,144,0.6); margin-bottom: 2rem;">Fill out the form below and we'll contact you within one business day to schedule your complimentary consultation.</p>

                <form id="contact-form">
                    <div style="margin-bottom: 1.25rem;">
                        <label for="name" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Full Name *</label>
                        <input type="text" id="name" name="name" required style="width: 100%; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 8px; background: #fff; color: var(--navy); font-size: 1rem; font-family: var(--font-family);">
                    </div>

                    <div style="margin-bottom: 1.25rem;">
                        <label for="email" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Email Address *</label>
                        <input type="email" id="email" name="email" required style="width: 100%; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 8px; background: #fff; color: var(--navy); font-size: 1rem; font-family: var(--font-family);">
                    </div>

                    <div style="margin-bottom: 1.25rem;">
                        <label for="phone" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Phone Number *</label>
                        <input type="tel" id="phone" name="phone" required style="width: 100%; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 8px; background: #fff; color: var(--navy); font-size: 1rem; font-family: var(--font-family);">
                    </div>

                    <div style="margin-bottom: 1.25rem;">
                        <label for="savings" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Retirement Savings Amount</label>
                        <select id="savings" name="savings" style="width: 100%; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 8px; background: #fff; color: var(--navy); font-size: 1rem; font-family: var(--font-family);">
                            <option value="">Please select</option>
                            <option value="$250K - $500K">$250K - $500K</option>
                            <option value="$500K - $1M">$500K - $1M</option>
                            <option value="$1M - $2M">$1M - $2M</option>
                            <option value="$2M+">$2M+</option>
                        </select>
                    </div>

                    <div style="margin-bottom: 1.25rem;">
                        <label for="retirement-timeline" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Retirement Timeline</label>
                        <select id="retirement-timeline" name="retirement-timeline" style="width: 100%; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 8px; background: #fff; color: var(--navy); font-size: 1rem; font-family: var(--font-family);">
                            <option value="">Please select</option>
                            <option value="Already retired">Already retired</option>
                            <option value="1-2 years">1-2 years</option>
                            <option value="3-5 years">3-5 years</option>
                            <option value="5-10 years">5-10 years</option>
                            <option value="10+ years">10+ years</option>
                        </select>
                    </div>

                    <div style="margin-bottom: 1.75rem;">
                        <label for="questions" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Questions or Comments</label>
                        <textarea id="questions" name="questions" rows="4" placeholder="Tell us about your retirement planning goals or any specific questions you have..." style="width: 100%; padding: 0.85rem; border: 1px solid rgba(0,0,0,0.12); border-radius: 8px; background: #fff; color: var(--navy); font-size: 1rem; resize: vertical; font-family: var(--font-family);"></textarea>
                    </div>

                    <!-- Honeypot -->
                    <div style="position:absolute;left:-9999px;"><input type="text" name="website" tabindex="-1" autocomplete="off"></div>

                    <button type="submit" id="submit-btn" class="titan-hero-btn-primary" style="width: 100%; justify-content: center;">REQUEST CONSULTATION <span>→</span></button>
                    <div id="form-status" style="margin-top: 12px; text-align: center; font-weight: 500;"></div>
                </form>

                <script>
                document.getElementById('contact-form').addEventListener('submit', async function(e) {
                  e.preventDefault();
                  var btn = document.getElementById('submit-btn');
                  var status = document.getElementById('form-status');

                  // Honeypot check
                  if (this.querySelector('[name="website"]').value) return;

                  btn.disabled = true;
                  btn.innerHTML = 'SENDING...';
                  status.textContent = '';

                  // Get first-touch tracking data from cookie
                  function getCookie(name) {
                    var value = '; ' + document.cookie;
                    var parts = value.split('; ' + name + '=');
                    if (parts.length === 2) return parts.pop().split(';').shift();
                    return null;
                  }

                  var trackingData = {};
                  try {
                    var cookieData = getCookie('cw_first_touch');
                    if (cookieData) {
                      trackingData = JSON.parse(cookieData);
                    }
                  } catch (e) {}

                  try {
                    var res = await fetch('/api/submit-lead', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({
                        name: document.getElementById('name').value,
                        email: document.getElementById('email').value,
                        phone: document.getElementById('phone').value,
                        savings: document.getElementById('savings').value,
                        retirementTimeline: document.getElementById('retirement-timeline').value,
                        questions: document.getElementById('questions').value,
                        utm_source: trackingData.utm_source || '',
                        utm_medium: trackingData.utm_medium || '',
                        utm_campaign: trackingData.utm_campaign || '',
                        utm_content: trackingData.utm_content || '',
                        utm_term: trackingData.utm_term || '',
                        referrer: trackingData.referrer || '',
                        landing_page: trackingData.landing_page || '',
                        submitted_from: window.location.pathname
                      })
                    });
                    var data = await res.json();
                    if (res.ok) {
                      status.style.color = '#2d8a4e';
                      status.textContent = data.message || "Thank you! We'll be in touch within one business day.";
                      this.reset();
                    } else {
                      status.style.color = '#c0392b';
                      status.textContent = data.error || 'Something went wrong. Please try again.';
                    }
                  } catch (err) {
                    status.style.color = '#c0392b';
                    status.textContent = 'Network error. Please try again or call us at 801.210.2800.';
                  }
                  btn.disabled = false;
                  btn.innerHTML = 'REQUEST CONSULTATION <span>→</span>';
                });
                </script>

                <p style="font-size: 0.85rem; color: rgba(25,79,144,0.45); margin-top: 1.5rem; line-height: 1.6;">By submitting this form, you agree to be contacted by Capital Wealth Advisors regarding your retirement planning needs. We respect your privacy and will never share your information.</p>
            </div>

            {# Office Details #}
            <div>
                <div style="background: #fff; border-radius: 12px; padding: 2rem; margin-bottom: 1.5rem;">
                    <h3 style="font-family: var(--font-family); font-size: 1.3rem; font-weight: 600; color: var(--navy); margin-bottom: 1.5rem;">Office Information</h3>
                    <div style="margin-bottom: 1.5rem;">
                        <p style="font-weight: 600; color: var(--navy); margin-bottom: 0.5rem;">Address</p>
                        <p style="color: rgba(25,79,144,0.65); line-height: 1.6;">1850 W Ashton Blvd, Suite 175<br>Lehi, UT 84043</p>
                    </div>
                    <div style="margin-bottom: 1.5rem;">
                        <p style="font-weight: 600; color: var(--navy); margin-bottom: 0.5rem;">Phone</p>
                        <p style="color: rgba(25,79,144,0.65);"><a href="tel:8012102800" style="color: var(--navy); text-decoration: none; font-weight: 500;">801.210.2800</a></p>
                    </div>
                    <div style="margin-bottom: 1.5rem;">
                        <p style="font-weight: 600; color: var(--navy); margin-bottom: 0.5rem;">Email</p>
                        <p style="color: rgba(25,79,144,0.65);"><a href="mailto:info@capitalwealth.com" style="color: var(--navy); text-decoration: none; font-weight: 500;">info@capitalwealth.com</a></p>
                    </div>
                    <div>
                        <p style="font-weight: 600; color: var(--navy); margin-bottom: 0.5rem;">Hours</p>
                        <p style="color: rgba(25,79,144,0.65); line-height: 1.6;">Monday - Friday: 9am - 5pm<br>Virtual meetings available nationwide</p>
                    </div>
                </div>

                <div style="background: var(--navy); border-radius: 12px; padding: 2rem; color: #fff;">
                    <h3 style="font-family: var(--font-family); font-size: 1.2rem; font-weight: 600; margin-bottom: 1rem;">Prefer to Call?</h3>
                    <p style="color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; line-height: 1.6;">We're happy to answer your questions over the phone and schedule a time that works for you.</p>
                    <a href="tel:8012102800" class="titan-hero-btn-secondary" style="background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); color: #fff; width: 100%; justify-content: center;">CALL 801.210.2800 <span>→</span></a>
                </div>
            </div>
        </div>
    </div>
</section>

{# Responsive stacking #}
<style>
@media (max-width: 900px) {
    section[style*="padding: 5rem 2rem;"] > div > div[style*="grid-template-columns: 1.2fr 1fr"] {
        grid-template-columns: 1fr !important;
    }
}
</style>
