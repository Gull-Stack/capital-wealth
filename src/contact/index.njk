{# Hero section with editorial layout #}
<section class="contact-hero-section">
  <div class="contact-hero-container">
    <div class="contact-hero-text">
      <div class="contact-eyebrow">PRIVATE CONSULTATION</div>
      <h1 class="contact-hero-title">Start a Conversation About Your Retirement</h1>
      <p class="contact-hero-subtitle">No pressure. No pitch. Just a conversation about your goals and whether we're the right fit. Initial consultations are complimentary for qualified families.</p>
      
      <div class="advisory-team">
        <div class="team-photos">
          <img src="/assets/images/mike-stevens.jpg" alt="Mike Stevens, Capital Wealth Advisor" class="team-photo">
          <div class="team-photo placeholder">+</div>
        </div>
        <div class="team-label">Dedicated Advisory Team</div>
      </div>
    </div>
    
    <div class="contact-form-card">
      <h2 class="contact-form-title">Request a Consultation</h2>
      <p class="contact-form-subtitle">Fill out the form below and we'll contact you within one business day to schedule your complimentary consultation.</p>
      
      <form id="contact-form">
        <div class="contact-form-grid">
          <div class="contact-form-field">
            <label for="first_name" class="contact-form-label">First Name *</label>
            <input type="text" id="first_name" name="first_name" required class="contact-form-input">
          </div>
          
          <div class="contact-form-field">
            <label for="last_name" class="contact-form-label">Last Name *</label>
            <input type="text" id="last_name" name="last_name" required class="contact-form-input">
          </div>
          
          <div class="contact-form-field">
            <label for="email" class="contact-form-label">Email Address *</label>
            <input type="email" id="email" name="email" required class="contact-form-input">
          </div>
          
          <div class="contact-form-field">
            <label for="phone" class="contact-form-label">Phone Number *</label>
            <input type="tel" id="phone" name="phone" required class="contact-form-input">
          </div>
          
          <div class="contact-form-field">
            <label for="savings" class="contact-form-label">Savings Amount</label>
            <select id="savings" name="savings" class="contact-form-select">
              <option value="">Please select</option>
              <option value="$250K - $500K">$250K - $500K</option>
              <option value="$500K - $1M">$500K - $1M</option>
              <option value="$1M - $2M">$1M - $2M</option>
              <option value="$2M+">$2M+</option>
            </select>
          </div>
          
          <div class="contact-form-field">
            <label for="retirement-timeline" class="contact-form-label">Retirement Timeline</label>
            <select id="retirement-timeline" name="retirement-timeline" class="contact-form-select">
              <option value="">Please select</option>
              <option value="Already retired">Already retired</option>
              <option value="1-2 years">1-2 years</option>
              <option value="3-5 years">3-5 years</option>
              <option value="5-10 years">5-10 years</option>
              <option value="10+ years">10+ years</option>
            </select>
          </div>
          
          <div class="contact-form-field full-width">
            <label for="questions" class="contact-form-label">Questions or Comments</label>
            <textarea id="questions" name="questions" rows="4" placeholder="Tell us about your retirement planning goals or any specific questions you have..." class="contact-form-textarea"></textarea>
          </div>
        </div>
        
        <!-- SMS opt-in -->
        <div class="contact-form-field full-width" style="margin-top: 0.5rem;">
          <label class="sms-opt-in-label">
            <input type="checkbox" id="sms_opt_in" name="sms_opt_in" value="yes" style="width: auto; margin-right: 0.5rem; accent-color: #16253C;">
            <span style="font-family: var(--font-body); font-size: 0.8rem; color: #64748b; line-height: 1.4;">By checking this box and signing up for texts, you consent to receive appointment reminders, account notifications, and text messages from Capital Wealth at the number provided. Consent is not a condition of purchase. Message and data rates may apply. Message frequency varies. Reply STOP to opt out or HELP for help. <a href="/disclosures/" style="color: #16253C; text-decoration: underline;">Privacy Policy</a> and <a href="/terms/" style="color: #16253C; text-decoration: underline;">Terms</a>.</span>
          </label>
        </div>
        
        <!-- Honeypot fields — invisible to humans, irresistible to bots -->
        <div class="honeypot"><input type="text" name="website" tabindex="-1" autocomplete="off"></div>
        <div class="honeypot"><input type="text" name="company_url" tabindex="-1" autocomplete="off"></div>
        
        <button type="submit" id="submit-btn" class="contact-form-submit">SCHEDULE YOUR VISIT →</button>
        <div id="form-status" style="margin-top: 12px; text-align: center; font-weight: 500;"></div>
      </form>
      
      <script>
      // Track when the page loaded for time-based spam check
      var formLoadTime = Date.now();

      document.getElementById('contact-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = document.getElementById('submit-btn');
        var status = document.getElementById('form-status');

        // Honeypot check — bots auto-fill hidden fields
        if (this.querySelector('[name="website"]').value || this.querySelector('[name="company_url"]').value) return;

        // Time-based check — reject if submitted in under 3 seconds (bots are instant)
        var timeSinceLoad = (Date.now() - formLoadTime) / 1000;
        if (timeSinceLoad < 3) {
          status.textContent = 'Please take a moment to fill out the form.';
          status.style.color = '#ba1a1a';
          return;
        }

        btn.disabled = true;
        btn.innerHTML = 'SENDING...';
        status.textContent = '';

        // Get first-touch tracking data from cookie
        function getCookie(name) {
          var value = '; ' + document.cookie;
          var parts = value.split('; ' + name + '=');
          if (parts.length === 2) return parts.pop().split(';').shift();
          return null;
        }

        var trackingData = {};
        try {
          var cookieData = getCookie('cw_first_touch');
          if (cookieData) {
            trackingData = JSON.parse(cookieData);
          }
        } catch (e) {}

        // Combine first and last name
        var fullName = document.getElementById('first_name').value + ' ' + document.getElementById('last_name').value;

        try {
          var res = await fetch('/api/submit-lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: fullName,
              email: document.getElementById('email').value,
              phone: document.getElementById('phone').value,
              savings: document.getElementById('savings').value,
              retirementTimeline: document.getElementById('retirement-timeline').value,
              questions: document.getElementById('questions').value,
              utm_source: trackingData.utm_source || '',
              utm_medium: trackingData.utm_medium || '',
              utm_campaign: trackingData.utm_campaign || '',
              utm_content: trackingData.utm_content || '',
              utm_term: trackingData.utm_term || '',
              referrer: trackingData.referrer || '',
              landing_page: trackingData.landing_page || '',
              submitted_from: window.location.pathname
            })
          });
          var data = await res.json();
          if (res.ok) {
            status.style.color = '#2d8a4e';
            status.textContent = "Thank you! Redirecting you to schedule your consultation...";
            this.reset();
            setTimeout(function() {
              window.location.href = '/thank-you/';
            }, 1500);
          } else {
            status.style.color = '#c0392b';
            status.textContent = data.error || 'Something went wrong. Please try again.';
          }
        } catch (err) {
          status.style.color = '#c0392b';
          status.textContent = 'Network error. Please try again or call us at 801.210.2800.';
        }
        btn.disabled = false;
        btn.innerHTML = 'REQUEST CONSULTATION →';
      });
      </script>
      
      <p class="contact-form-disclaimer">By submitting this form, you agree to be contacted by Capital Wealth regarding your retirement planning needs including SMS outreach. We respect your privacy and will never share your information.</p>
    </div>
  </div>
</section>

