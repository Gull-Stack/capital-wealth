                    <h4 class="text-accent mt-lg">Parking:</h4>
                    <p>Free parking is available in front of the building and in the adjacent parking lot.</p>
                </div>
            </div>
            
            <div class="card">
                <h3>Office Building Details</h3>
                <p>We're located in a modern office complex with easy access and ample parking. Look for the Capital Wealth Advisors sign in the lobby directory.</p>
                
                <div class="mt-md">
                    <span class="service-tag">Suite 175</span>
                    <span class="service-tag">Second Floor</span>
                    <span class="service-tag">Elevator Available</span>
                </div>
                
                <p class="mt-lg">If you have trouble finding our office, please call {{ site.phone }} and we'll be happy to guide you in.</p>
            </div>
        </div>
    </div>
</section>

<!-- Emergency Contact -->
<section class="section">
    <div class="container">
        <div class="text-center">
            <h2>Have Questions? We're Here to Help</h2>
            <p class="text-lg">Don't wait to start planning your financial future. Contact us today to schedule your complimentary consultation.</p>
            
            <div class="hero-cta mt-lg">
                <a href="tel:{{ site.phone }}" class="btn btn-primary btn-lg">Call {{ site.phone }}</a>
                <a href="mailto:{{ site.email }}" class="btn btn-secondary btn-lg">Email {{ site.email }}</a>
            </div>
            
            <p class="mt-md text-muted">Initial consultations are complimentary for qualified families with $500K+ in retirement savings.</p>
        </div>
    </div>
</section>