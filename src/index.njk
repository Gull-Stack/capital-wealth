<!-- Keep all existing JavaScript functionality -->
<script>
// Intersection Observer for reveal animations
const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
};

const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');
        }
    });
}, observerOptions);

// Apply reveal animation to all animated elements
document.addEventListener('DOMContentLoaded', () => {
    // Hero elements - stagger from top
    const heroElements = document.querySelectorAll('.hero-animate');
    heroElements.forEach((el, index) => {
        el.style.transitionDelay = `${0.2 + index * 0.15}s`;
        observer.observe(el);
    });

    // Hero image
    const heroImage = document.querySelector('.finpay-hero-image');
    if (heroImage) {
        heroImage.style.transitionDelay = '0.4s';
        observer.observe(heroImage);
    }

    // Stats fly in from right with stagger
    const stats = document.querySelectorAll('.finpay-stat');
    stats.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.15}s`;
        observer.observe(el);
    });

    // Service cards
    const cards = document.querySelectorAll('.finpay-card, .finpay-service-card');
    cards.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.1}s`;
        observer.observe(el);
    });

    // Federal cards
    const federalCards = document.querySelectorAll('.federal-card');
    federalCards.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.12}s`;
        observer.observe(el);
    });

    // Meet Mike
    const mikeElements = document.querySelectorAll('.meet-mike-photo, .meet-mike-details');
    mikeElements.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.2}s`;
        observer.observe(el);
    });

    // Book section
    const bookElements = document.querySelectorAll('.book-left, .book-right');
    bookElements.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.2}s`;
        observer.observe(el);
    });

    // Comparison table
    const compElements = document.querySelectorAll('.finpay-comparison-content');
    compElements.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.08}s`;
        observer.observe(el);
    });

    // Comparison table rows stagger
    const compRows = document.querySelectorAll('.finpay-comp-row:not(.finpay-comp-header)');
    compRows.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.06}s`;
        observer.observe(el);
    });

    // Any editorial-reveal elements
    const editorialReveals = document.querySelectorAll('.editorial-reveal, .reveal-from-left, .reveal-from-right, .reveal-scale');
    editorialReveals.forEach((el, index) => {
        observer.observe(el);
    });
});

// ═══════════════════════════════════════════════════════════
// PARALLAX SCROLL ENGINE
// Smooth depth-based movement on scroll
// ═══════════════════════════════════════════════════════════
(function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    let ticking = false;

    // Hero parallax: image moves slower than scroll, quote card slightly different
    function updateParallax() {
        const scrollTop = window.pageYOffset;
        const heroSection = document.querySelector('.finpay-hero');
        
        if (heroSection) {
            const heroBottom = heroSection.offsetTop + heroSection.offsetHeight;
            if (scrollTop < heroBottom) {
                const heroImage = heroSection.querySelector('.finpay-hero-image');
                const quoteCard = heroSection.querySelector('.hero-quote-card');
                const watermark = heroSection.querySelector('.mountain-logo-bg');

                if (heroImage) {
                    heroImage.style.transform = `translateY(${scrollTop * 0.08}px)`;
                }
                if (quoteCard) {
                    // Float the quote card with parallax offset
                    const baseFloat = Math.sin(Date.now() / 1000) * 6;
                    quoteCard.style.transform = `translateY(${(scrollTop * -0.12) + baseFloat}px)`;
                }
                if (watermark) {
                    watermark.style.transform = `translate(-50%, -50%) scale(${1 + scrollTop * 0.0003})`;
                }
            }
        }

        // Subtle parallax on section decorative elements
        const floatingAccents = document.querySelectorAll('.floating-accent');
        floatingAccents.forEach((el, i) => {
            const speed = 0.03 + (i * 0.02);
            el.style.transform = `translateY(${scrollTop * speed}px)`;
        });

        ticking = false;
    }

    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(updateParallax);
            ticking = true;
        }
    }, { passive: true });
})();

// ═══════════════════════════════════════════════════════════
// SMOOTH COUNTER ANIMATION
// Animate stat numbers from 0 on scroll-in
// ═══════════════════════════════════════════════════════════
(function() {
    const statNumbers = document.querySelectorAll('.finpay-stat-number');
    const animated = new Set();
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && !animated.has(entry.target)) {
                animated.add(entry.target);
                const el = entry.target;
                const finalText = el.textContent;
                const numMatch = finalText.match(/[\d,]+/);
                if (!numMatch) return;
                
                const numStr = numMatch[0].replace(/,/g, '');
                const target = parseInt(numStr);
                const prefix = finalText.substring(0, finalText.indexOf(numMatch[0]));
                const suffix = finalText.substring(finalText.indexOf(numMatch[0]) + numMatch[0].length);
                const hasComma = numMatch[0].includes(',');
                const duration = 1800;
                const start = performance.now();
                
                function step(now) {
                    const elapsed = now - start;
                    const progress = Math.min(elapsed / duration, 1);
                    // Ease out cubic
                    const eased = 1 - Math.pow(1 - progress, 3);
                    const current = Math.floor(target * eased);
                    const formatted = hasComma ? current.toLocaleString() : current.toString();
                    el.textContent = prefix + formatted + suffix;
                    if (progress < 1) requestAnimationFrame(step);
                    else el.textContent = finalText; // Restore exact original
                }
                requestAnimationFrame(step);
            }
        });
    }, { threshold: 0.5 });
    
    statNumbers.forEach(el => counterObserver.observe(el));
})();

// Enhanced Testimonials Carousel
let currentTestimonialIndex = 0;
const testimonials = document.querySelectorAll('.testimonial-card');
const dots = document.querySelectorAll('.dot');
let testimonialInterval;

function showTestimonial(index) {
    // Hide all testimonials
    testimonials.forEach(testimonial => {
        testimonial.classList.remove('active');
    });
    
    // Remove active from all dots
    dots.forEach(dot => {
        dot.classList.remove('active');
    });
    
    // Show current testimonial
    if (testimonials[index]) {
        testimonials[index].classList.add('active');
    }
    
    // Activate current dot
    if (dots[index]) {
        dots[index].classList.add('active');
    }
    
    currentTestimonialIndex = index;
}

function nextTestimonial() {
    const nextIndex = (currentTestimonialIndex + 1) % testimonials.length;
    showTestimonial(nextIndex);
}

function currentTestimonial(index) {
    showTestimonial(index - 1); // Convert from 1-based to 0-based
    
    // Restart auto-rotation
    clearInterval(testimonialInterval);
    startTestimonialRotation();
}

function startTestimonialRotation() {
    testimonialInterval = setInterval(nextTestimonial, 5000); // Change every 5 seconds
}

// Initialize testimonials on page load
document.addEventListener('DOMContentLoaded', () => {
    if (testimonials.length > 0) {
        showTestimonial(0);
        startTestimonialRotation();
    }
});

// Enhanced Sticky CTA functionality with proper session persistence
document.addEventListener('DOMContentLoaded', () => {
    let stickyShown = false;
    let ctaDismissed = sessionStorage.getItem('cwa-cta-dismissed') === 'true';
    const stickyCta = document.getElementById('sticky-cta');
    
    if (!stickyCta) return;
    
    function showStickyCta() {
        if (!stickyShown && !ctaDismissed && stickyCta) {
            stickyCta.style.transform = 'translateY(0)';
            stickyShown = true;
        }
    }
    
    function hideStickyCta(temporary = false) {
        if (stickyCta) {
            stickyCta.style.transform = 'translateY(120%)';
            stickyShown = false;
            
            // If not temporarily hiding, mark as dismissed for session
            if (!temporary) {
                ctaDismissed = true;
                sessionStorage.setItem('cwa-cta-dismissed', 'true');
            }
        }
    }
    
    // Show/hide based on scroll position - only if not dismissed
    window.addEventListener('scroll', () => {
        if (ctaDismissed) return;
        
        const heroHeight = document.querySelector('.finpay-hero')?.offsetHeight || 600;
        const footerTop = document.querySelector('.finpay-footer')?.offsetTop || 9999;
        const scrollTop = window.pageYOffset;
        const windowHeight = window.innerHeight;
        
        if (scrollTop > heroHeight && (scrollTop + windowHeight) < footerTop - 200) {
            showStickyCta();
        } else {
            hideStickyCta(true); // Temporarily hide, don't mark as dismissed
        }
    });
    
    // Close button functionality - permanently dismiss for session
    document.getElementById('close-sticky-cta')?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        hideStickyCta(false); // Permanently dismiss
    });
    
    // Initialize - hide if already dismissed
    if (ctaDismissed) {
        stickyCta.style.transform = 'translateY(120%)';
    }
});
</script>

