/* Ensure proper loading animations */
.finpay-card,
.finpay-stat,
.federal-stat {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
}

.finpay-card.visible,
.finpay-stat.visible,
.federal-stat.visible {
    opacity: 1;
    transform: translateY(0);
}
</style>

<script>
// Intersection Observer for reveal animations
const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
};

const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');
        }
    });
}, observerOptions);

// Apply reveal animation to cards and stats
document.addEventListener('DOMContentLoaded', () => {
    const revealElements = document.querySelectorAll('.finpay-card, .finpay-stat, .federal-stat');
    
    revealElements.forEach((el, index) => {
        el.style.transitionDelay = `${index * 0.1}s`;
        observer.observe(el);
    });
});

// Sticky CTA popup functionality
document.addEventListener('DOMContentLoaded', () => {
    let stickyShown = false;
    const stickyCta = document.getElementById('sticky-cta');
    
    function showStickyCta() {
        if (!stickyShown && stickyCta) {
            stickyCta.style.transform = 'translateY(0)';
            stickyShown = true;
        }
    }
    
    function hideStickyCta() {
        if (stickyCta) {
            stickyCta.style.transform = 'translateY(100%)';
            stickyShown = false;
        }
    }
    
    // Show after scrolling past hero section
    window.addEventListener('scroll', () => {
        const heroHeight = document.querySelector('.finpay-hero')?.offsetHeight || 600;
        const footerTop = document.querySelector('.finpay-footer')?.offsetTop || 9999;
        const scrollTop = window.pageYOffset;
        const windowHeight = window.innerHeight;
        
        if (scrollTop > heroHeight && (scrollTop + windowHeight) < footerTop - 200) {
            showStickyCta();
        } else {
            hideStickyCta();
        }
    });
    
    // Close button functionality
    document.getElementById('close-sticky-cta')?.addEventListener('click', () => {
        hideStickyCta();
        sessionStorage.setItem('cta-dismissed', 'true');
    });
    
    // Don't show if user already dismissed it this session
    if (sessionStorage.getItem('cta-dismissed')) {
        hideStickyCta();
    }
});
</script>

<!-- Sticky Bottom CTA Popup -->
<div id="sticky-cta" style="
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(135deg, #194F90 0%, #15437a 100%);
    color: white;
    padding: 1rem 1.5rem;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 1000;
    ">
    <div style="display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto;">
        <div style="flex: 1;">
            <h4 style="margin: 0 0 0.25rem 0; font-size: 1.125rem; font-weight: 600;">Ready to retire with confidence?</h4>
            <p style="margin: 0; font-size: 0.875rem; opacity: 0.9;">Get your complimentary retirement assessment today.</p>
        </div>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/contact/" style="
                background: #F09F54; 
                color: white; 
                padding: 0.75rem 1.5rem; 
                border-radius: 8px; 
                font-weight: 600; 
                text-decoration: none; 
                transition: all 0.2s ease;
                font-size: 0.875rem;
                white-space: nowrap;
                " 
                onmouseover="this.style.background='#e8904a'" 
                onmouseout="this.style.background='#F09F54'">
                Schedule Free Call
            </a>
            <button id="close-sticky-cta" style="
                background: none; 
                border: none; 
                color: white; 
                font-size: 1.25rem; 
                cursor: pointer; 
                padding: 0.5rem;
                opacity: 0.7;
                transition: opacity 0.2s ease;
                " 
                onmouseover="this.style.opacity='1'" 
                onmouseout="this.style.opacity='0.7'">
                ×
            </button>
        </div>
    </div>
</div>