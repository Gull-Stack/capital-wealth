  font-size: 0.9rem;
  line-height: 1.6;
  margin-bottom: auto;
}

.pillar-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 1.25rem;
  padding: 0.4rem 1rem;
