  margin: 0 auto;
  background: rgba(194, 198, 210, 0.2);
  border-bottom: 3px solid var(--primary);
}

.pillar-card {
  background: var(--surface-container-lowest);
  padding: 2rem 1.5rem;
  min-height: 360px;
  display: flex;
  flex-direction: column;
  text-align: left;
  transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  opacity: 0;
  transform: translateY(30px);
  position: relative;
  overflow: hidden;
  border-right: 1px solid rgba(194, 198, 210, 0.2);
}

.pillar-card:last-child {
  border-right: none;
}

.pillar-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 3px;
  background: var(--secondary);
  transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

.pillar-card:hover::after {
  width: 100%;
}

.pillar-card:nth-child(3) {
  background: var(--surface-container-lowest);
}

.pillar-card.animate {
  opacity: 1;
  transform: translateY(0);
}

.pillar-card:hover {
  background: white;
  box-shadow: 0 8px 30px rgba(0, 56, 112, 0.06);
}

.pillar-icon {
  margin-bottom: 1.25rem;
}

.pillar-icon svg {
  stroke: var(--secondary);
  transition: all 0.3s ease;
}

.pillar-card:hover .pillar-icon svg {
  stroke: var(--primary);
  transform: scale(1.1);
}

.pillar-title {
  font-family: var(--font-serif-display);
  font-size: 1.2rem;
  font-weight: 400;
  font-style: italic;
