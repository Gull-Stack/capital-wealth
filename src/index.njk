/* SDBA Section */
.sdba-section {
  padding: 4rem 2rem;
  background: var(--surface-container-low);
}

.sdba-content {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
