// PARALLAX SCROLL ENGINE
// Smooth depth-based movement on scroll
// ═══════════════════════════════════════════════════════════
(function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    let ticking = false;

    // Hero parallax: image moves slower than scroll, quote card slightly different
    function updateParallax() {
        const scrollTop = window.pageYOffset;
        const heroSection = document.querySelector('.finpay-hero');
        
        if (heroSection) {
            const heroBottom = heroSection.offsetTop + heroSection.offsetHeight;
            if (scrollTop < heroBottom) {
                const heroImage = heroSection.querySelector('.finpay-hero-image');
                const quoteCard = heroSection.querySelector('.hero-quote-card');
                const watermark = heroSection.querySelector('.mountain-logo-bg');

                if (heroImage) {
                    heroImage.style.transform = `translateY(${scrollTop * 0.08}px)`;
                }
                if (quoteCard) {
                    // Float the quote card with parallax offset
                    const baseFloat = Math.sin(Date.now() / 1000) * 6;
                    quoteCard.style.transform = `translateY(${(scrollTop * -0.12) + baseFloat}px)`;
                }
                if (watermark) {
                    watermark.style.transform = `translate(-50%, -50%) scale(${1 + scrollTop * 0.0003})`;
                }
            }
        }

        // Subtle parallax on section decorative elements
        const floatingAccents = document.querySelectorAll('.floating-accent');
        floatingAccents.forEach((el, i) => {
            const speed = 0.03 + (i * 0.02);
            el.style.transform = `translateY(${scrollTop * speed}px)`;
        });

        ticking = false;
    }

    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(updateParallax);
            ticking = true;
        }
    }, { passive: true });
})();

// ═══════════════════════════════════════════════════════════
// SMOOTH COUNTER ANIMATION
// Animate stat numbers from 0 on scroll-in
// ═══════════════════════════════════════════════════════════
(function() {
    const statNumbers = document.querySelectorAll('.finpay-stat-number');
    const animated = new Set();
    
    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && !animated.has(entry.target)) {
                animated.add(entry.target);
                const el = entry.target;
                const finalText = el.textContent;
                const numMatch = finalText.match(/[\d,]+/);
                if (!numMatch) return;
                
                const numStr = numMatch[0].replace(/,/g, '');
                const target = parseInt(numStr);
                const prefix = finalText.substring(0, finalText.indexOf(numMatch[0]));
                const suffix = finalText.substring(finalText.indexOf(numMatch[0]) + numMatch[0].length);
                const hasComma = numMatch[0].includes(',');
                const duration = 1800;
                const start = performance.now();
                
                function step(now) {
                    const elapsed = now - start;
                    const progress = Math.min(elapsed / duration, 1);
                    // Ease out cubic
                    const eased = 1 - Math.pow(1 - progress, 3);
                    const current = Math.floor(target * eased);
                    const formatted = hasComma ? current.toLocaleString() : current.toString();
                    el.textContent = prefix + formatted + suffix;
                    if (progress < 1) requestAnimationFrame(step);
                    else el.textContent = finalText; // Restore exact original
                }
                requestAnimationFrame(step);
            }
        });
    }, { threshold: 0.5 });
    
    statNumbers.forEach(el => counterObserver.observe(el));
})();



// Enhanced Sticky CTA functionality with proper session persistence
document.addEventListener('DOMContentLoaded', () => {
    let stickyShown = false;
    let ctaDismissed = sessionStorage.getItem('cwa-cta-dismissed') === 'true';
    const stickyCta = document.getElementById('sticky-cta');
    
    if (!stickyCta) return;
    
    function showStickyCta() {
        if (!stickyShown && !ctaDismissed && stickyCta) {
            stickyCta.style.transform = 'translateY(0)';
            stickyShown = true;
        }
    }
    
    function hideStickyCta(temporary = false) {
        if (stickyCta) {
            stickyCta.style.transform = 'translateY(120%)';
            stickyShown = false;
            
            // If not temporarily hiding, mark as dismissed for session
            if (!temporary) {
                ctaDismissed = true;
                sessionStorage.setItem('cwa-cta-dismissed', 'true');
            }
        }
    }
    
    // Show/hide based on scroll position - only if not dismissed
    window.addEventListener('scroll', () => {
        if (ctaDismissed) return;
        
        const heroHeight = document.querySelector('.finpay-hero')?.offsetHeight || 600;
        const footerTop = document.querySelector('.finpay-footer')?.offsetTop || 9999;
        const scrollTop = window.pageYOffset;
        const windowHeight = window.innerHeight;
        
        if (scrollTop > heroHeight && (scrollTop + windowHeight) < footerTop - 200) {
            showStickyCta();
        } else {
            hideStickyCta(true); // Temporarily hide, don't mark as dismissed
        }
    });
    
    // Close button functionality - permanently dismiss for session
    document.getElementById('close-sticky-cta')?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        hideStickyCta(false); // Permanently dismiss
    });
    
    // Initialize - hide if already dismissed
    if (ctaDismissed) {
        stickyCta.style.transform = 'translateY(120%)';
    }
});
</script>

