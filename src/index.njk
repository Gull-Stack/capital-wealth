.testimonials-content {
  max-width: 1200px;
  margin: 0 auto;
}

.testimonials-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.testimonial-card {
  background: white;
  border-radius: 16px;
  padding: 2rem;
  border-top: 4px solid var(--primary);
}

.testimonial-card.animate {
  opacity: 1;
  transform: translateY(0);
}

.testimonial-quote {
  font-family: var(--font-serif-display);
  font-style: italic;
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--on-surface);
  margin-bottom: 1.5rem;
}

.testimonial-author {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--on-surface-variant);
}

/* Final CTA Section */
.final-cta {
  padding: 4rem 2rem;
  background: var(--surface-container-low);
}

.final-cta-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

.final-cta-content {
  text-align: left;
}

.final-cta-title {
  font-family: var(--font-serif-display);
  font-size: clamp(2.2rem, 4vw, 3rem);
  font-style: italic;
  font-weight: 300;
  color: var(--primary);
  margin-bottom: 0.75rem;
}

.final-cta-subtitle {
  font-size: 1rem;
  color: var(--on-surface-variant);
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.final-cta-image-wrap {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
}

.final-cta-image {
  width: 100%;
  height: 350px;
  object-fit: cover;
  animation: kenBurnsCta 25s ease-in-out infinite alternate;
}

@keyframes kenBurnsCta {
  0% { transform: scale(1) translate(0, 0); }
  100% { transform: scale(1.06) translate(-1.5%, -1%); }
}

.final-cta-glass {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.35);
  border-radius: 16px;
  padding: 1rem 1.5rem;
}

.final-cta-glass span {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--primary);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.final-cta-glass span::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--secondary);
}

.fiduciary-promise {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--on-surface-variant);
  margin-top: 0.75rem;
}

/* Animation Classes */
.reveal-on-scroll {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.8s ease;
}

.reveal-on-scroll.animate {
  opacity: 1;
  transform: translateY(0);
}

/* Responsive Design */
@media (max-width: 1024px) {
  .pillars-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .pillar-card:nth-child(3) {
    transform: none;
  }

  .federal-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .testimonials-grid {
    grid-template-columns: 1fr;
  }
}

