<style>
/* Hero Section */
.hero-fullbleed {
  position: relative;
  height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  padding-bottom: 5rem;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0,20,40,0.45) 0%, rgba(0,20,40,0.25) 50%, rgba(0,20,40,0.5) 100%);
  z-index: 2;
}

/* Animated sun rays — anchored to sun position in photo (upper-left) */
.hero-sunrays {
  position: absolute;
  top: -5%;
  left: 8%;
  width: 500px;
  height: 500px;
  z-index: 2;
  pointer-events: none;
  background: conic-gradient(
    from 180deg at 50% 50%,
    transparent 0deg,
    rgba(255, 210, 120, 0.08) 8deg,
    transparent 16deg,
    rgba(255, 195, 100, 0.06) 30deg,
    transparent 38deg,
    rgba(255, 220, 140, 0.07) 52deg,
    transparent 60deg,
    rgba(255, 200, 110, 0.05) 75deg,
    transparent 83deg,
    rgba(255, 215, 130, 0.06) 98deg,
    transparent 106deg,
    rgba(255, 205, 115, 0.04) 120deg,
    transparent 128deg,
    transparent 360deg
  );
  filter: blur(8px);
  animation: sunPulse 6s ease-in-out infinite;
  transform-origin: 50% 50%;
}

@keyframes sunPulse {
  0%, 100% { opacity: 0.6; transform: rotate(0deg) scale(1); }
  50% { opacity: 1; transform: rotate(3deg) scale(1.08); }
}

.hero-content {
  position: relative;
  z-index: 3;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 4rem;
  width: 100%;
  text-align: left;
}

/* hero content visible by default — no JS animation dependency */

.hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 1.25rem;
  display: inline-flex;
  align-items: center;
