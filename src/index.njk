}

/* Comparison Section */
.comparison-section {
  padding: 4rem 2rem;
  background: var(--surface);
  position: relative;
  overflow: hidden;
}

.comparison-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: url('/assets/images/logos/logo-icon-color.png');
  background-size: 80px;
  background-repeat: repeat;
  background-position: 0 0;
  opacity: 0.015;
  z-index: 0;
  pointer-events: none;
  animation: staggerBg 30s linear infinite;
}

@keyframes staggerBg {
  0% { background-position: 0 0; }
  100% { background-position: 80px 80px; }
}

.comparison-section > * {
