---
layout: layouts/base-finpay.njk
title: "Retirement Planning Blog | Capital Wealth Advisors"
description: "Expert retirement planning articles covering Social Security, tax strategies, estate planning, and income optimization from Capital Wealth Advisors in Lehi, Utah."
permalink: /blog/
eleventyExcludeFromCollections: true
breadcrumbs:
  - { name: "Home", url: "/" }
  - { name: "Blog", url: "/blog/" }
---

{# ═══════════════════════════════════════════════════════════
   HERO SECTION — Finpay-inspired clean design
   ═══════════════════════════════════════════════════════════ #}
<section class="finpay-blog-hero">
    <div class="container">
        <div class="finpay-blog-hero-content">
            <h1>Expert insights for your retirement</h1>
            <p class="finpay-blog-hero-subtitle">Tax strategies, planning guides, and financial wisdom from Utah's retirement specialists.</p>
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════════════════
   FEATURED SECTION — Clean card-based layout
   ═══════════════════════════════════════════════════════════ #}
<section class="finpay-blog-featured">
    <div class="container">
        <h2>Featured Articles</h2>
        
        {# Featured Post Grid #}
        <div class="finpay-blog-featured-grid">
            {% set featuredPost = collections.blog | reverse | first %}
            {% for post in collections.blog %}
                {% if post.data.featured %}
                    {% set featuredPost = post %}
                {% endif %}
            {% endfor %}
            
            {# Main Featured Post #}
            <div class="finpay-blog-featured-main">
                <a href="{{ featuredPost.url }}" class="finpay-blog-featured-card">
                    <div class="finpay-blog-featured-content">
                        <span class="finpay-blog-featured-label">Featured</span>
                        <h3>{{ featuredPost.data.title }}</h3>
                        <p>{{ featuredPost.data.description or featuredPost.templateContent | striptags | truncate(150) }}</p>
                        <div class="finpay-blog-featured-meta">
                            <time>{{ featuredPost.data.date | date }}</time>
                            <span>→</span>
                        </div>
                    </div>
                </a>
            </div>

            {# Recent Articles Sidebar #}
            <div class="finpay-blog-featured-sidebar">
                <h4>Latest Articles</h4>
                {% for post in collections.blog | reverse | slice(1, 4) %}
                <a href="{{ post.url }}" class="finpay-blog-recent-article">
                    <h5>{{ post.data.title }}</h5>
                    <time>{{ post.data.date | date }}</time>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SEARCH & FILTERS — Clean Finpay-inspired interface
   ═══════════════════════════════════════════════════════════ #}
<section class="finpay-blog-search">
    <div class="container">
        <div class="finpay-blog-search-bar">
            <input type="text" id="blogSearch" placeholder="Search articles..." class="finpay-search-input">
        </div>
        <div class="finpay-blog-filters" id="blogTagFilters">
            <!-- Tags will be generated by JavaScript -->
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════════════════
   ARTICLES LIST — Clean card grid
   ═══════════════════════════════════════════════════════════ #}
<section class="finpay-blog-articles">
    <div class="container">
        <div class="finpay-blog-articles-grid" id="blogArticlesList">
            {% for post in collections.blog | reverse %}
            <article class="finpay-blog-article-card" data-title="{{ post.data.title | lower }}" data-description="{{ post.data.description | lower }}" data-tags="{{ post.data.tags | join(',') | lower }}">
                <a href="{{ post.url }}" class="finpay-blog-article-link">
                    <div class="finpay-blog-article-content">
                        <h3>{{ post.data.title }}</h3>
                        <p>{{ post.data.description or post.templateContent | striptags | truncate(120) }}</p>
                        <div class="finpay-blog-article-meta">
                            <time>{{ post.data.date | date }}</time>
                            <span class="finpay-blog-article-arrow">→</span>
                        </div>
                    </div>
                </a>
            </article>
            {% endfor %}
        </div>
        
        <div class="finpay-blog-pagination" id="blogPagination">
            <!-- Pagination will be generated by JavaScript -->
        </div>
    </div>
</section>

{# ═══════════════════════════════════════════════════════════
   NEWSLETTER SIGNUP — Clean CTA section
   ═══════════════════════════════════════════════════════════ #}
<section class="finpay-blog-newsletter">
    <div class="container">
        <div class="finpay-newsletter-content">
            <h2>Stay informed about retirement planning</h2>
            <p>Get our latest insights delivered to your inbox monthly.</p>
            <a href="/contact/" class="finpay-btn-primary">Schedule a Consultation</a>
        </div>
    </div>
</section>

<style>
/* Finpay-inspired Blog Styles */
.finpay-blog-hero {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    padding: 4rem 0;
    margin-bottom: 4rem;
}

.finpay-blog-hero-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
}

.finpay-blog-hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #194F90;
    margin-bottom: 1rem;
    line-height: 1.2;
}

.finpay-blog-hero-subtitle {
    font-size: 1.25rem;
    color: #525252;
    margin: 0;
    line-height: 1.5;
}

/* Featured Section */
.finpay-blog-featured {
    margin-bottom: 4rem;
}

.finpay-blog-featured h2 {
    font-size: 2rem;
    font-weight: 600;
    color: #194F90;
    margin-bottom: 2rem;
}

.finpay-blog-featured-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
}

.finpay-blog-featured-card {
    display: block;
    text-decoration: none;
    background: white;
    border-radius: 12px;
    padding: 2rem;
    border: 1px solid #e5e7eb;
    transition: all 0.2s ease;
    height: fit-content;
}

.finpay-blog-featured-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    border-color: #194F90;
}

.finpay-blog-featured-label {
    background: #F09F54;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
    display: inline-block;
}

.finpay-blog-featured-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #194F90;
    margin-bottom: 1rem;
    line-height: 1.3;
}

.finpay-blog-featured-card p {
    color: #525252;
    line-height: 1.6;
    margin-bottom: 1.5rem;
}

.finpay-blog-featured-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #737373;
    font-size: 0.875rem;
}

.finpay-blog-featured-meta span {
    color: #F09F54;
    font-weight: 600;
}

/* Featured Sidebar */
.finpay-blog-featured-sidebar h4 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #194F90;
    margin-bottom: 1.5rem;
}

.finpay-blog-recent-article {
    display: block;
    text-decoration: none;
    padding: 1rem 0;
    border-bottom: 1px solid #e5e7eb;
    transition: all 0.2s ease;
}

.finpay-blog-recent-article:hover {
    background: #f8fafc;
    padding-left: 0.5rem;
}

.finpay-blog-recent-article h5 {
    font-size: 1rem;
    font-weight: 600;
    color: #404040;
    margin-bottom: 0.5rem;
    line-height: 1.4;
}

.finpay-blog-recent-article time {
    color: #737373;
    font-size: 0.875rem;
}

/* Search Section */
.finpay-blog-search {
    background: #f8fafc;
    padding: 2rem 0;
    margin-bottom: 3rem;
}

.finpay-search-input {
    width: 100%;
    max-width: 500px;
    padding: 0.75rem 1rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 1rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s ease;
}

.finpay-search-input:focus {
    outline: none;
    border-color: #194F90;
    box-shadow: 0 0 0 3px rgba(25, 79, 144, 0.1);
}

.finpay-blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.blog-tag-pill {
    padding: 0.5rem 1rem;
    background: white;
    border: 1px solid #d1d5db;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
}

.blog-tag-pill:hover,
.blog-tag-pill.active {
    background: #194F90;
    color: white;
    border-color: #194F90;
}

/* Articles Grid */
.finpay-blog-articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.finpay-blog-article-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    overflow: hidden;
    transition: all 0.2s ease;
}

.finpay-blog-article-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    border-color: #194F90;
}

.finpay-blog-article-link {
    display: block;
    text-decoration: none;
    padding: 1.5rem;
}

.finpay-blog-article-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #194F90;
    margin-bottom: 0.75rem;
    line-height: 1.4;
}

.finpay-blog-article-content p {
    color: #525252;
    line-height: 1.6;
    margin-bottom: 1rem;
}

.finpay-blog-article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #737373;
    font-size: 0.875rem;
}

.finpay-blog-article-arrow {
    color: #F09F54;
    font-weight: 600;
    transition: transform 0.2s ease;
}

.finpay-blog-article-card:hover .finpay-blog-article-arrow {
    transform: translateX(4px);
}

/* Newsletter Section */
.finpay-blog-newsletter {
    background: linear-gradient(135deg, #194F90 0%, #15437a 100%);
    color: white;
    padding: 3rem 0;
    text-align: center;
    margin-top: 4rem;
}

.finpay-newsletter-content h2 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1rem;
}

.finpay-newsletter-content p {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
}

/* Pagination */
.finpay-blog-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 3rem;
}

.blog-pagination-btn,
.blog-pagination-num {
    padding: 0.5rem 0.75rem;
    border: 1px solid #d1d5db;
    background: white;
    color: #525252;
    border-radius: 6px;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
}

.blog-pagination-btn:hover:not(.disabled),
.blog-pagination-num:hover {
    background: #194F90;
    color: white;
    border-color: #194F90;
}

.blog-pagination-num.active {
    background: #194F90;
    color: white;
    border-color: #194F90;
}

.blog-pagination-btn.disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.blog-pagination-dots {
    color: #737373;
    padding: 0 0.5rem;
}

/* Mobile Responsiveness */
@media (max-width: 768px) {
    .finpay-blog-hero h1 {
        font-size: 2rem;
    }
    
    .finpay-blog-featured-grid {
        grid-template-columns: 1fr;
    }
    
    .finpay-blog-articles-grid {
        grid-template-columns: 1fr;
    }
    
    .finpay-blog-filters {
        justify-content: center;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('blogSearch');
    const tagFiltersContainer = document.getElementById('blogTagFilters');
    const articlesContainer = document.getElementById('blogArticlesList');
    const paginationContainer = document.getElementById('blogPagination');
    
    const allArticles = Array.from(document.querySelectorAll('.finpay-blog-article-card'));
    let filteredArticles = [...allArticles];
    let currentPage = 1;
    const articlesPerPage = 9;
    let activeTagFilter = null;
    
    // Generate tag filters
    const allTags = new Set();
    allArticles.forEach(article => {
        const tags = article.dataset.tags.split(',').filter(tag => tag.trim() && tag !== 'blog');
        tags.forEach(tag => allTags.add(tag.trim()));
    });
    
    if (allTags.size > 0) {
        const allButton = document.createElement('button');
        allButton.textContent = 'All';
        allButton.className = 'blog-tag-pill active';
        allButton.addEventListener('click', () => filterByTag(null));
        tagFiltersContainer.appendChild(allButton);
        
        allTags.forEach(tag => {
            const button = document.createElement('button');
            button.textContent = tag.charAt(0).toUpperCase() + tag.slice(1).replace('-', ' ');
            button.className = 'blog-tag-pill';
            button.dataset.tag = tag;
            button.addEventListener('click', () => filterByTag(tag));
            tagFiltersContainer.appendChild(button);
        });
    }
    
    // Search functionality
    function searchArticles(query) {
        if (!query.trim()) {
            return allArticles;
        }
        
        const searchTerms = query.toLowerCase().split(' ').filter(term => term.length > 0);
        
        return allArticles.filter(article => {
            const title = article.dataset.title;
            const description = article.dataset.description;
            const tags = article.dataset.tags;
            const searchContent = `${title} ${description} ${tags}`;
            
            return searchTerms.every(term => searchContent.includes(term));
        });
    }
    
    // Tag filtering
    function filterByTag(tag) {
        activeTagFilter = tag;
        
        document.querySelectorAll('.blog-tag-pill').forEach(btn => {
            btn.classList.remove('active');
        });
        
        if (tag) {
            document.querySelector(`[data-tag="${tag}"]`).classList.add('active');
            filteredArticles = allArticles.filter(article => 
                article.dataset.tags.includes(tag)
            );
        } else {
            document.querySelector('.blog-tag-pill').classList.add('active');
            filteredArticles = [...allArticles];
        }
        
        const searchQuery = searchInput.value.trim();
        if (searchQuery) {
            filteredArticles = searchArticles(searchQuery).filter(article => 
                activeTagFilter ? article.dataset.tags.includes(activeTagFilter) : true
            );
        }
        
        currentPage = 1;
        updateDisplay();
    }
    
    // Search input handler
    searchInput.addEventListener('input', function() {
        const query = this.value.trim();
        
        if (query) {
            let searchResults = searchArticles(query);
            if (activeTagFilter) {
                searchResults = searchResults.filter(article => 
                    article.dataset.tags.includes(activeTagFilter)
                );
            }
            filteredArticles = searchResults;
        } else {
            filteredArticles = activeTagFilter 
                ? allArticles.filter(article => article.dataset.tags.includes(activeTagFilter))
                : [...allArticles];
        }
        
        currentPage = 1;
        updateDisplay();
    });
    
    // Update display with pagination
    function updateDisplay() {
        allArticles.forEach(article => {
            article.style.display = 'none';
        });
        
        const totalPages = Math.ceil(filteredArticles.length / articlesPerPage);
        const startIndex = (currentPage - 1) * articlesPerPage;
        const endIndex = startIndex + articlesPerPage;
        const pageArticles = filteredArticles.slice(startIndex, endIndex);
        
        pageArticles.forEach(article => {
            article.style.display = 'block';
        });
        
        updatePagination(totalPages);
    }
    
    // Update pagination controls
    function updatePagination(totalPages) {
        paginationContainer.innerHTML = '';
        
        if (totalPages <= 1) return;
        
        const prevButton = document.createElement('button');
        prevButton.textContent = '← Previous';
        prevButton.className = 'blog-pagination-btn' + (currentPage === 1 ? ' disabled' : '');
        prevButton.disabled = currentPage === 1;
        prevButton.addEventListener('click', () => {
            if (currentPage > 1) {
                currentPage--;
                updateDisplay();
            }
        });
        paginationContainer.appendChild(prevButton);
        
        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || Math.abs(i - currentPage) <= 1) {
                const pageButton = document.createElement('button');
                pageButton.textContent = i;
                pageButton.className = 'blog-pagination-num' + (i === currentPage ? ' active' : '');
                pageButton.addEventListener('click', () => {
                    currentPage = i;
                    updateDisplay();
                });
                paginationContainer.appendChild(pageButton);
            } else if (Math.abs(i - currentPage) === 2) {
                const dots = document.createElement('span');
                dots.textContent = '...';
                dots.className = 'blog-pagination-dots';
                paginationContainer.appendChild(dots);
            }
        }
        
        const nextButton = document.createElement('button');
        nextButton.textContent = 'Next →';
        nextButton.className = 'blog-pagination-btn' + (currentPage === totalPages ? ' disabled' : '');
        nextButton.disabled = currentPage === totalPages;
        nextButton.addEventListener('click', () => {
            if (currentPage < totalPages) {
                currentPage++;
                updateDisplay();
            }
        });
        paginationContainer.appendChild(nextButton);
    }
    
    // Initial display
    updateDisplay();
});
</script>