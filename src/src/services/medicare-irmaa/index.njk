<!-- IRMAA Thresholds -->
<section class="section section-dark">
    <div class="container">
        <h2 class="text-center mb-xl">IRMAA Income Thresholds</h2>

        <div class="grid grid-cols-2">
            <div class="card">
                <h3 class="text-accent">Single Filers</h3>
                <div class="mt-md" style="font-size: 0.9rem; color: var(--text-secondary);">
                    <ul style="margin-left: 1rem;">
                        <li>Under $103,000: Standard premium</li>
                        <li>$103,000 - $129,000: +$69.90/month</li>
                        <li>$129,000 - $161,000: +$174.70/month</li>
                        <li>$161,000 - $193,000: +$279.50/month</li>
                        <li>$193,000 - $500,000: +$384.30/month</li>
                        <li>Over $500,000: +$419.30/month</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <h3 class="text-accent">Married Filing Jointly</h3>
                <div class="mt-md" style="font-size: 0.9rem; color: var(--text-secondary);">
                    <ul style="margin-left: 1rem;">
                        <li>Under $206,000: Standard premium</li>
                        <li>$206,000 - $258,000: +$69.90/month</li>
                        <li>$258,000 - $322,000: +$174.70/month</li>
                        <li>$322,000 - $386,000: +$279.50/month</li>
                        <li>$386,000 - $750,000: +$384.30/month</li>
                        <li>Over $750,000: +$419.30/month</li>
                    </ul>
                </div>
                <p class="mt-md text-muted">Thresholds are per-person surcharges applied to each spouse individually.</p>
            </div>
        </div>
    </div>
</section>

