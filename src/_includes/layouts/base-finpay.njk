    <script>
    (function(){
        var shell = document.getElementById('cwhShell');
        var ham   = document.getElementById('cwhHam');
        var draw  = document.getElementById('cwhDrawer');
        var scrim = document.getElementById('cwhScrim');
        var close = document.getElementById('cwhDrawerClose');

        if (shell) {
            window.addEventListener('scroll', function(){
                shell.classList.toggle('cwh-scrolled', window.scrollY > 12);
            }, { passive: true });
        }

        function open(){
            draw.classList.add('cwh-active');
            scrim.classList.add('cwh-active');
            ham.classList.add('cwh-active');
            ham.setAttribute('aria-expanded', 'true');
            draw.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }
        function shut(){
            draw.classList.remove('cwh-active');
            scrim.classList.remove('cwh-active');
            ham.classList.remove('cwh-active');
            ham.setAttribute('aria-expanded', 'false');
            draw.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        if (ham)   ham.addEventListener('click', function(){ draw.classList.contains('cwh-active') ? shut() : open(); });
        if (close) close.addEventListener('click', shut);
        if (scrim) scrim.addEventListener('click', shut);
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') shut(); });

        document.querySelectorAll('.cwh-acc-trig').forEach(function(trig){
            trig.addEventListener('click', function(){
                var acc = trig.closest('.cwh-acc');
                var isOpen = acc.classList.contains('cwh-open');
                document.querySelectorAll('.cwh-acc').forEach(function(a){
                    a.classList.remove('cwh-open');
                    var t = a.querySelector('.cwh-acc-trig');
                    if (t) t.setAttribute('aria-expanded', 'false');
                });
                if (!isOpen) {
                    acc.classList.add('cwh-open');
                    trig.setAttribute('aria-expanded', 'true');
                }
            });
        });
    })();
    </script>

