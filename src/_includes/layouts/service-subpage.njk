---
layout: layouts/base-finpay.njk
---

<style>
/* Editorial CSS Variables */
:root {
  /* Typography */
  --font-serif-display: 'Cormorant Garamond', serif;
  --font-body: 'Manrope', sans-serif;
  --font-mono: 'Geist Mono', monospace;
  
  /* Colors */
  --primary: #194F90;
  --secondary: #14427A;
  --accent: #F09F54;
  --text-primary: #1A1A1A;
  --text-secondary: #6B7280;
  --background: #FFFFFF;
  --border: #E5E7EB;
  --highlight: rgba(240, 159, 84, 0.1);
  
  /* Spacing */
  --section-padding: 4rem 0;
  --container-padding: 0 2rem;
  
  /* Border Radius */
  --radius: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;
  --radius-xl: 1rem;
}

/* Service Subpage Layout Styles */
.service-header {
  background: var(--background);
  padding: 3rem 0 4rem;
  text-align: center;
}

.service-header-inner {
  max-width: 800px;
  margin: 0 auto;
  padding: var(--container-padding);
}

.service-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 1rem;
}

.service-title {
  font-family: var(--font-serif-display);
  font-style: italic;
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  font-weight: 400;
  line-height: 1.1;
  color: var(--primary);
  margin-bottom: 1.5rem;
}

.service-subtitle {
  font-family: var(--font-body);
  font-size: 1.25rem;
  line-height: 1.6;
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 auto;
}

/* Content area */
.service-content {
  /* Content is injected here via {{ content | safe }} */
}

/* Related Blog Posts */
.related-posts {
  background: #F9FAFB;
  padding: 4rem 0 5rem;
  margin-top: 4rem;
}

.related-posts-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: var(--container-padding);
}

.related-posts-header {
  text-align: center;
  margin-bottom: 3rem;
}

.related-posts-header h2 {
  font-family: var(--font-serif-display);
  font-style: italic;
  font-size: 2.25rem;
  font-weight: 400;
  color: var(--primary);
  margin-bottom: 0.5rem;
}

.related-posts-subtitle {
  font-family: var(--font-body);
  color: var(--text-secondary);
  font-size: 1.125rem;
}

.related-posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 1px;
  background: var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.related-post-card {
  background: white;
  padding: 2rem;
  text-decoration: none;
  transition: all 0.2s ease;
  position: relative;
  border-bottom: 3px solid transparent;
}

.related-post-card:hover {
  border-bottom-color: var(--accent);
  transform: translateY(-2px);
}

.related-post-date {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-secondary);
  margin-bottom: 0.75rem;
}

.related-post-title {
  font-family: var(--font-body);
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.4;
  color: var(--text-primary);
  margin-bottom: 0.75rem;
}

.related-post-link {
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Navy CTA Section */
.service-cta {
  background: var(--primary);
  padding: 4rem 0;
  text-align: center;
  color: white;
}

.service-cta-inner {
  max-width: 600px;
  margin: 0 auto;
  padding: var(--container-padding);
}

.service-cta h2 {
  font-family: var(--font-serif-display);
  font-style: italic;
  font-size: 2.5rem;
  font-weight: 400;
  margin-bottom: 1rem;
}

.service-cta p {
  font-family: var(--font-body);
  font-size: 1.125rem;
  line-height: 1.6;
  margin-bottom: 2rem;
  opacity: 0.9;
}

.service-cta-button {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 1rem 2rem;
  background: white;
  color: var(--primary);
  border-radius: 10px;
  text-decoration: none;
  transition: all 0.2s ease;
}

.service-cta-button:hover {
  background: #f8f9fa;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

/* Responsive Design */
@media (max-width: 768px) {
  .service-header {
    padding: 2rem 0 3rem;
  }
  
  .service-title {
    font-size: 2.5rem;
  }
  
  .service-subtitle {
    font-size: 1.125rem;
  }
  
  .related-posts-grid {
    grid-template-columns: 1fr;
  }
  
  .related-posts {
    padding: 3rem 0 4rem;
  }
  
  .service-cta {
    padding: 3rem 0;
  }
  
  .service-cta h2 {
    font-size: 2rem;
  }
}
</style>

<!-- Service Header -->
<section class="service-header">
  <div class="service-header-inner">
    {% if serviceLabel %}
      <p class="service-eyebrow">{{ serviceLabel }}</p>
    {% endif %}
    
    {% if serviceTitle %}
      <h1 class="service-title">{{ serviceTitle }}</h1>
    {% else %}
      <h1 class="service-title">{{ title }}</h1>
    {% endif %}
    
    {% if serviceSubtitle %}
      <p class="service-subtitle">{{ serviceSubtitle }}</p>
    {% elif description %}
      <p class="service-subtitle">{{ description }}</p>
    {% endif %}
  </div>
</section>

<!-- Service Content -->
<div class="service-content">
  {{ content | safe }}
</div>

<!-- Related Blog Posts -->
{% if collections.blog and collections.blog.length > 0 %}
  {% set relatedPosts = [] %}
  {% if serviceTag or tags %}
    {% set searchTags = [serviceTag] if serviceTag else tags %}
    {% if searchTags %}
      {% for post in collections.blog %}
        {% if post.data.tags %}
          {% for tag in searchTags %}
            {% if tag in post.data.tags and post.url != page.url %}
              {% set relatedPosts = (relatedPosts.push(post), relatedPosts) %}
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endif %}
  
  <!-- If no tag matches, get 3 recent blog posts -->
  {% if relatedPosts.length == 0 %}
    {% set relatedPosts = collections.blog | reverse | slice(0, 3) %}
  {% endif %}
  
  {% if relatedPosts.length > 0 %}
    <section class="related-posts">
      <div class="related-posts-inner">
        <div class="related-posts-header">
          <h2>Related Reading</h2>
          <p class="related-posts-subtitle">Dive deeper into this topic</p>
        </div>
        
        <div class="related-posts-grid">
          {% for post in relatedPosts.slice(0, 3) %}
            <a href="{{ post.url }}" class="related-post-card">
              <div class="related-post-date">{{ post.date | date("MMMM DD, YYYY") }}</div>
              <h3 class="related-post-title">{{ post.data.title }}</h3>
              <div class="related-post-link">Read More →</div>
            </a>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
{% endif %}

<!-- Navy CTA (skip on contact page) -->
{% if page.url and '/contact/' not in page.url %}
  <section class="service-cta">
    <div class="service-cta-inner">
      <h2>Ready to Take the Next Step?</h2>
      <p>Schedule a complimentary consultation to discuss your financial goals and see how we can help you achieve them.</p>
      <a href="/contact/" class="service-cta-button">
        Schedule Consultation
        <span>→</span>
      </a>
    </div>
  </section>
{% endif %}