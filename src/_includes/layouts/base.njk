<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ title or site.title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    
    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Finpay-inspired Helvetica fonts -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        /* Fallback to system fonts for Helvetica-like appearance */
        :root {
            --font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
        }
    </style>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/assets/images/logos/favicon.png">
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XNE17HRDX8"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XNE17HRDX8');
      gtag('config', 'G-LD4VE3SQNT');
    </script>

    <!-- Main styles -->
    <link rel="stylesheet" href="/assets/css/main.css">
    <!-- Finpay-inspired styles -->
    <link rel="stylesheet" href="/assets/css/finpay-inspired.css">
    
    <!-- Schema JSON-LD: Organization + LocalBusiness + FinancialService -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": ["FinancialService", "LocalBusiness", "Organization"],
        "@id": "{{ site.url }}/#organization",
        "name": "{{ site.title }}",
        "legalName": "Capital Wealth Advisors, LLC",
        "description": "{{ site.description }}",
        "url": "{{ site.url }}",
        "telephone": "{{ site.phone }}",
        "email": "{{ site.email }}",
        "foundingDate": "2009",
        "numberOfEmployees": { "@type": "QuantitativeValue", "value": 5 },
        "slogan": "Strategic Income & Tax Planning for Your Retirement",
        "knowsAbout": ["Retirement Planning", "FERS Federal Benefits", "TSP Planning", "Roth Conversions", "Social Security Optimization", "Medicare IRMAA", "Tax-Efficient Withdrawals", "Estate Planning", "401k Rollovers", "Fiduciary Financial Advice"],
        "logo": "{{ site.url }}/assets/images/logos/logo-horizontal-color.png",
        "image": "{{ site.url }}/assets/images/photos/CWA-Mountain-Couple-home-header.webp",
        "sameAs": ["https://www.linkedin.com/in/mstevens317/"],
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "{{ site.address.street }}",
            "addressLocality": "{{ site.address.city }}",
            "addressRegion": "{{ site.address.state }}",
            "postalCode": "{{ site.address.zip }}",
            "addressCountry": "US"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 40.4167,
            "longitude": -111.8908
        },
        "openingHoursSpecification": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "08:00",
            "closes": "17:00"
        },
        "priceRange": "$$",
        "currenciesAccepted": "USD",
        "paymentAccepted": "Advisory Fee",
        "founder": {
            "@type": "Person",
            "name": "{{ site.founder.name }}",
            "jobTitle": "{{ site.founder.title }}",
            "description": "Investment Adviser Representative, fiduciary, host of Retire Right Radio, author of Retire Right Retire Now",
            "sameAs": "https://www.linkedin.com/in/mstevens317/"
        },
        "areaServed": [
            { "@type": "State", "name": "Utah" },
            { "@type": "State", "name": "Idaho" },
            { "@type": "Country", "name": "United States" }
        ],
        "hasCredential": [
            { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "Series 66 Investment Adviser Representative" },
            { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "California Insurance License #0G96805" }
        ],
        "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Financial Advisory Services",
            "itemListElement": [
                {% for service in site.services %}
                {
                    "@type": "Offer",
                    "itemOffered": {
                        "@type": "Service",
                        "name": "{{ service.name }}",
                        "description": "{{ service.description }}"
                    }
                }{% if not loop.last %},{% endif %}
                {% endfor %}
            ]
        }
    }
    </script>
    
    <!-- Google Reviews Schema for GEO Enhancement -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Capital Wealth Advisors",
        "url": "{{ site.url }}",
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "5.0",
            "reviewCount": "8",
            "bestRating": "5",
            "worstRating": "1"
        },
        "review": [
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Julie E." },
                "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
                "reviewBody": "My wife and I, as well as my mother-in-law, have been working with the Capital Wealth team for over a year and have found Mike and his staff to be very welcoming and knowledgeable. They lay out the best advice and options for our financial well-being, and they make sure we understand the full picture before making decisions.",
                "publisher": { "@type": "Organization", "name": "Google" }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Cory M." },
                "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
                "reviewBody": "We've been extremely pleased with our experience at Capital Wealth. The team is professional, responsive, and truly invested in helping us achieve our financial goals. They take the time to explain everything clearly and make us feel confident about our retirement plan.",
                "publisher": { "@type": "Organization", "name": "Google" }
            },
            {
                "@type": "Review",
                "author": { "@type": "Person", "name": "Collette D." },
                "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
                "reviewBody": "Mike and his staff are the best! We previously were with two other financial planners whose fees were too high and their investment ability had no comparison to Mike. He was also the only one who addressed taxes. Mike got our retirement finances completely organized and set up for the long haul.",
                "publisher": { "@type": "Organization", "name": "Google" }
