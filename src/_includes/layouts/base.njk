    <style>
    /* Mobile Navigation Styles */
    .mobile-menu-button {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        margin-left: 1rem;
    }

    .hamburger-line {
        display: block;
        width: 24px;
        height: 3px;
        background: var(--gray-700);
        margin: 4px 0;
        transition: all 0.3s ease;
        border-radius: 2px;
    }

    .mobile-menu-button.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(6px, 6px);
    }

    .mobile-menu-button.active .hamburger-line:nth-child(2) {
        opacity: 0;
    }

    .mobile-menu-button.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
    }

    .mobile-nav-menu {
        position: fixed;
        top: 0;
        right: -100%;
        width: 320px;
        height: 100vh;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: -8px 0 32px rgba(0,0,0,0.08);
        border-left: 1px solid rgba(0,0,0,0.05);
        transition: right 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        z-index: 9999;
        overflow-y: auto;
    }

    .mobile-nav-menu.active {
        right: 0;
    }

    .mobile-nav-content {
        padding: 2rem 1.5rem;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .mobile-nav-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 2rem;
        border-bottom: 1px solid rgba(0,0,0,0.08);
        margin-bottom: 2rem;
    }

    .mobile-menu-close {
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        color: var(--gray-600);
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    .mobile-menu-close:hover {
        background: rgba(0,0,0,0.05);
        color: var(--gray-800);
    }

    .mobile-nav-links {
        flex: 1;
    }

    .mobile-nav-section {
        margin-bottom: 0.5rem;
    }

    .mobile-dropdown-toggle {
        width: 100%;
        background: none;
        border: none;
        padding: 1rem 0;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--gray-700);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-align: left;
    }

    .mobile-dropdown-toggle:hover {
        color: var(--cw-primary);
    }

    .dropdown-arrow {
        transition: transform 0.3s ease;
    }

    .mobile-dropdown-toggle.active .dropdown-arrow {
        transform: rotate(180deg);
    }

    .mobile-dropdown-menu {
        max-height: 0;
        overflow: hidden;
        padding-left: 1rem;
        transition: max-height 0.3s ease;
    }

    .mobile-dropdown-menu.active {
        max-height: 300px;
    }

    .mobile-dropdown-menu a {
        display: block;
        padding: 0.75rem 0;
        color: var(--gray-600);
        text-decoration: none;
        font-size: 0.95rem;
        border-bottom: 1px solid var(--gray-100);
    }

    .mobile-dropdown-menu a:hover {
        color: var(--cw-primary);
    }

    .mobile-nav-link {
        display: block;
        padding: 1rem 0;
        color: var(--gray-700);
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 500;
        border-bottom: 1px solid var(--gray-100);
    }

    .mobile-nav-link:hover {
        color: var(--cw-primary);
    }

    .mobile-nav-cta {
        padding-top: 2rem;
        border-top: 1px solid rgba(0,0,0,0.08);
        margin-top: auto;
    }

    .mobile-cta-btn {
        display: block;
        background: var(--cw-primary);
        color: white;
        padding: 1rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s ease;
    }

    .mobile-cta-btn:hover {
        background: var(--cw-secondary);
        transform: translateY(-1px);
    }

    .mobile-cta-secondary {
        display: block;
        background: transparent;
        color: var(--cw-primary);
        border: 2px solid var(--cw-primary);
        padding: 1rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s ease;
        margin-top: 0.75rem;
    }

    .mobile-cta-secondary:hover {
        background: var(--cw-primary);
        color: white;
        transform: translateY(-1px);
    }

    .mobile-nav-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.15);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        z-index: 9998;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .mobile-nav-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    /* Responsive Navigation Breakpoints */
    @media (max-width: 1024px) {
        .finpay-nav-links.desktop-nav {
            display: none;
        }

        .mobile-menu-button {
            display: block;
        }

        .finpay-nav {
            justify-content: space-between;
        }

        .finpay-nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-left: auto;
        }

        .client-login {
            font-size: 0.875rem;
            order: 1;
        }

        .mobile-menu-button {
            order: 2;
        }

        .desktop-cta {
            display: none;
        }
    }

    @media (min-width: 1025px) {
        .mobile-menu-button {
            display: none !important;
        }

        .mobile-nav-menu {
            display: none !important;
        }

        .finpay-nav-right {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }
    }

    /* Enhanced responsive navigation */
    @media (max-width: 768px) {
        .finpay-nav {
            padding: var(--space-3) 0;
        }

        .finpay-nav-logo img {
            height: 32px;
        }

        .finpay-nav-right {
            gap: 0.75rem;
        }

        .client-login {
            font-size: 0.8rem;
            padding: 0.5rem 0.75rem;
        }

        .mobile-menu-button {
            padding: 4px;
        }

        .hamburger-line {
            width: 20px;
            height: 2.5px;
        }
    }
    </style>

    <script>
    // Mobile Navigation Functionality
    document.addEventListener('DOMContentLoaded', () => {
        console.log('DOMContentLoaded fired for mobile menu');
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenuClose = document.getElementById('mobile-menu-close');
        const mobileNavMenu = document.getElementById('mobile-nav-menu');
        const body = document.body;

        console.log('Mobile menu elements found:', {
            button: !!mobileMenuButton,
            close: !!mobileMenuClose,
            menu: !!mobileNavMenu
        });

        // Create overlay
        const overlay = document.createElement('div');
        overlay.className = 'mobile-nav-overlay';
        overlay.id = 'mobile-nav-overlay';
        body.appendChild(overlay);

        function openMobileMenu() {
            console.log('Opening mobile menu');
            if (mobileMenuButton) mobileMenuButton.classList.add('active');
            if (mobileNavMenu) mobileNavMenu.classList.add('active');
            overlay.classList.add('active');
            body.style.overflow = 'hidden';
        }

        function closeMobileMenu() {
            console.log('Closing mobile menu');
            if (mobileMenuButton) mobileMenuButton.classList.remove('active');
            if (mobileNavMenu) mobileNavMenu.classList.remove('active');
            overlay.classList.remove('active');
            body.style.overflow = '';
        }

        // Event listeners with better error handling
        if (mobileMenuButton) {
            console.log('Adding click listener to mobile menu button');
            mobileMenuButton.addEventListener('click', openMobileMenu);
        } else {
            console.error('Mobile menu button not found!');
        }
        
        if (mobileMenuClose) {
            mobileMenuClose.addEventListener('click', closeMobileMenu);
        }
        
        overlay.addEventListener('click', closeMobileMenu);

        // Mobile dropdown toggles
        const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');
        dropdownToggles.forEach(toggle => {
            toggle.addEventListener('click', () => {
                const targetId = toggle.getAttribute('data-target');
                const targetMenu = document.getElementById(targetId);
                
                toggle.classList.toggle('active');
                targetMenu.classList.toggle('active');
            });
        });

        // Close mobile menu when clicking nav links
        const mobileNavLinks = document.querySelectorAll('.mobile-nav-link, .mobile-dropdown-menu a, .mobile-cta-btn');
        mobileNavLinks.forEach(link => {
            link.addEventListener('click', closeMobileMenu);
        });

        // Close on escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileNavMenu.classList.contains('active')) {
                closeMobileMenu();
            }
        });
    });

    // Smooth scroll reveal animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, observerOptions);

    // Apply reveal animation to cards and sections
    document.addEventListener('DOMContentLoaded', () => {
        const revealElements = document.querySelectorAll('.finpay-service-card, .finpay-stat, .finpay-comparison-content');
        
        revealElements.forEach((el, index) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(20px)';
            el.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            observer.observe(el);
        });
    });

    // Header scroll effect
    let lastScrollTop = 0;
    const header = document.querySelector('.finpay-header');
    
    window.addEventListener('scroll', () => {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        if (scrollTop > 100) {
            header.style.background = 'rgba(255, 255, 255, 0.98)';
            header.style.boxShadow = '0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)';
        } else {
            header.style.background = 'rgba(255, 255, 255, 0.95)';
            header.style.boxShadow = 'none';
        }
        
        lastScrollTop = scrollTop;
    });
    </script>
</body>
</html>