{# ALSO SEEN ON — MEDIA LOGO BAR
   Usage: {% include "components/also-seen-on.njk" %}
   Place directly after the hero section on services & long-tail pages. #}

<style>
.aso-bar {
  background: #f4f5f7;
  padding: clamp(1.5rem, 3vw, 2.25rem) 0;
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
.aso-bar-inner {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 var(--space-6, 1.5rem);
  text-align: center;
}
.aso-bar-label {
  font-family: var(--font-mono, 'SF Mono', 'Fira Code', monospace);
  font-size: 0.65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: #7a7f8a;
  margin-bottom: 1.25rem;
  display: block;
}
.aso-bar-logos {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(2rem, 4vw, 3.5rem);
  flex-wrap: wrap;
}
.aso-bar-logos img {
  height: clamp(22px, 3vw, 32px);
  width: auto;
  object-fit: contain;
  opacity: 0.85;
  transition: opacity 0.25s ease;
}
.aso-bar-logos img:hover { opacity: 1; }

.aso-bar-logos img.aso-invert {
  filter: brightness(0) saturate(100%) opacity(0.6);
}
.aso-bar-logos img.aso-invert:hover {
  filter: brightness(0) saturate(100%) opacity(0.85);
}
@media (max-width: 600px) {
  .aso-bar-logos { gap: 1.5rem; }
  .aso-bar-logos img { height: 20px; }
}
</style>

<div class="aso-bar">
  <div class="aso-bar-inner">
    <span class="aso-bar-label">Also Seen On</span>
    <div class="aso-bar-logos">
      <img src="/assets/images/media/ksl-color.png" alt="KSL NewsRadio 102.7 FM" loading="lazy" />
      <img src="/assets/images/media/fortune-color.png" alt="Fortune" loading="lazy" />
      <img src="/assets/images/media/kslcom-color.png" alt="KSL.com" loading="lazy" />
      <img src="/assets/images/media/knrs-color.png" alt="TalkRadio 1059 KNRS" loading="lazy" />
      <img src="/assets/images/media/newstalk-color.png" alt="NewsTalk 107.9 FM" loading="lazy" />
      <img src="/assets/images/media/kid-color.png" alt="KID Radio" loading="lazy" />
    </div>
  </div>
</div>
