<script>
// Enhanced Federal Workshop Conversion Tracking
function trackFederalWorkshopRegistration() {
  console.log('Federal workshop registration tracked');
  
  // Facebook Pixel tracking
  if (typeof fbq !== 'undefined') {
    fbq('track', 'CompleteRegistration', {
      content_name: 'Federal Benefits Workshop April 9 2026',
      content_category: 'Workshop Registration',
      content_ids: ['federal-workshop-april-9-2026'],
      value: 750,
      currency: 'USD',
      predicted_ltv: 5000,
      custom_data: {
        workshop_date: '2026-04-09',
        location: 'Weber State University Davis Campus',
        target_audience: 'Hill AFB Federal Employees'
      }
    });
  }
  
  // Google Analytics tracking
  if (typeof gtag !== 'undefined') {
    gtag('event', 'federal_workshop_registration', {
      event_category: 'workshop',
      event_label: 'April 9 2026 Hill AFB',
      value: 750,
      workshop_date: '2026-04-09'
    });
  }
}

// Enhanced lead scoring for federal employees
function trackFederalBenefitsInterest() {
  if (typeof fbq !== 'undefined') {
    fbq('track', 'Lead', {
      content_name: 'Federal Benefits Workshop Interest',
      content_category: 'Federal Employee Lead',
      source: 'Landing Page Engagement',
      custom_data: {
        lead_quality: 'High - Federal Employee',
        interest_level: 'Workshop Attendance'
      }
    });
  }
}

// Track engagement at different scroll depths
let engagementTracked = {
  quarter: false,
  half: false,
  threequarter: false
};

window.addEventListener('scroll', function() {
  const scrollPercent = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
  
  if (!engagementTracked.quarter && scrollPercent > 25) {
    engagementTracked.quarter = true;
    if (typeof gtag !== 'undefined') {
      gtag('event', 'scroll_depth', { event_category: 'engagement', value: 25 });
    }
  }
  
  if (!engagementTracked.half && scrollPercent > 50) {
    engagementTracked.half = true;
    trackFederalBenefitsInterest();
  }
  
  if (!engagementTracked.threequarter && scrollPercent > 75) {
    engagementTracked.threequarter = true;
    if (typeof gtag !== 'undefined') {
      gtag('event', 'scroll_depth', { event_category: 'engagement', value: 75 });
    }
  }
});

// Form validation and enhancement
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('#federal-workshop-form');
  
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Basic validation
      const requiredFields = form.querySelectorAll('[required]');
      let isValid = true;
      
      requiredFields.forEach(field => {
        if (!field.value.trim()) {
          isValid = false;
          field.style.borderColor = '#dc2626';
        } else {
          field.style.borderColor = '#d1d5db';
        }
      });
      
      if (isValid) {
        trackFederalWorkshopRegistration();
        
        // Simulate form submission
        const submitBtn = form.querySelector('.federal-submit-btn');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Registering...';
        submitBtn.disabled = true;
        
        setTimeout(() => {
          window.location.href = '/federal-workshop-confirmed/';
        }, 1500);
      } else {
        alert('Please fill in all required fields.');
      }
    });
  }
});
</script>

