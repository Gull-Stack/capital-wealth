<!-- Registration Success Tracking Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('#registration-form');
  let scrollDepthTracked = { 25: false, 50: false, 75: false };
  
  // Form handling
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Validate form
      if (validateForm()) {
        trackRegistration();
        
        const submitBtn = form.querySelector('.submit-btn');
        submitBtn.textContent = 'Securing Your Spot...';
        submitBtn.disabled = true;
        
        // Simulate API call
        setTimeout(() => {
          window.location.href = '/federal-workshop-confirmed/';
        }, 2000);
      }
    });
    
    // Real-time validation
    const inputs = form.querySelectorAll('input[required], select[required]');
    inputs.forEach(input => {
      input.addEventListener('blur', () => validateField(input));
    });
  }
  
  function validateForm() {
    const requiredFields = form.querySelectorAll('input[required], select[required]');
    let isValid = true;
    
    requiredFields.forEach(field => {
      if (!validateField(field)) {
        isValid = false;
      }
    });
    
    return isValid;
  }
  
  function validateField(field) {
    const value = field.value.trim();
    let isValid = true;
    
    // Remove existing error
    field.style.borderColor = '';
    const errorMsg = field.parentNode.querySelector('.error-message');
    if (errorMsg) errorMsg.remove();
    
    // Required field check
    if (field.hasAttribute('required') && !value) {
      isValid = false;
      showError(field, 'This field is required');
    }
    
    // Email validation
    if (field.type === 'email' && value && !isValidEmail(value)) {
      isValid = false;
      showError(field, 'Please enter a valid email address');
    }
    
    // Phone validation
    if (field.type === 'tel' && value && !isValidPhone(value)) {
      isValid = false;
      showError(field, 'Please enter a valid phone number');
    }
    
    if (isValid) {
      field.style.borderColor = '#10B981';
    }
    
    return isValid;
  }
  
  function showError(field, message) {
    field.style.borderColor = '#DC2626';
    const errorDiv = document.createElement('div');
    errorDiv.className = 'error-message';
    errorDiv.style.cssText = 'color: #DC2626; font-size: 0.875rem; margin-top: 4px; font-weight: 600;';
    errorDiv.textContent = message;
    field.parentNode.appendChild(errorDiv);
  }
  
  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }
  
  function isValidPhone(phone) {
    return /^\(?[\d\s\-\(\)\+\.]{10,}$/.test(phone);
  }
  
  function trackRegistration() {
    // Facebook Pixel
    if (typeof fbq !== 'undefined') {
      fbq('track', 'CompleteRegistration', {
        content_name: 'Federal Benefits Workshop April 9 2026',
        content_category: 'Workshop Registration',
        content_ids: ['federal-workshop-april-9-2026'],
        value: 750,
        currency: 'USD'
      });
    }
    
    // Google Analytics
    if (typeof gtag !== 'undefined') {
      gtag('event', 'federal_workshop_registration', {
        event_category: 'workshop',
        event_label: 'April 9 2026 Hill AFB',
        value: 750
      });
    }
  }
  
  // Scroll depth tracking
  function trackScrollDepth() {
    const scrollPercent = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
    
    [25, 50, 75].forEach(percent => {
      if (!scrollDepthTracked[percent] && scrollPercent > percent) {
        scrollDepthTracked[percent] = true;
        if (typeof gtag !== 'undefined') {
          gtag('event', 'scroll_depth', {
            event_category: 'engagement',
            value: percent
          });
        }
      }
    });
  }
  
  window.addEventListener('scroll', trackScrollDepth);
  
  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
});
</script>

