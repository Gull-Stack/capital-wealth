<script>
// Track confirmation page view for conversion analytics
document.addEventListener('DOMContentLoaded', function() {
  // Facebook Pixel conversion tracking
  if (typeof fbq !== 'undefined') {
    fbq('track', 'CompleteRegistration', {
      content_name: 'Federal Benefits Workshop Registration Complete',
      content_category: 'Workshop Confirmation',
      content_ids: ['federal-workshop-april-9-2026'],
      value: 750,
      currency: 'USD'
    });
  }
  
  // Google Analytics conversion
  if (typeof gtag !== 'undefined') {
    gtag('event', 'conversion', {
      send_to: 'G-XNE17HRDX8/federal_workshop_registration',
      value: 750,
      currency: 'USD',
      transaction_id: Date.now().toString()
    });
  }
  
  // Track engagement with next steps
  const stepActions = document.querySelectorAll('.step-action');
  stepActions.forEach((action, index) => {
    action.addEventListener('click', function() {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'next_step_engagement', {
          event_category: 'post_registration',
          event_label: `Step ${index + 1}`,
          value: index + 1
        });
      }
    });
  });
});
</script>