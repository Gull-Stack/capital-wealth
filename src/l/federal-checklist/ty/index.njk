{# ═══════════ CONVERSION + ATTRIBUTION JS ═══════════ #}
<script>
(function () {
  'use strict';

  function killChrome() {
    ['.cwh-shell', '#cwhShell', 'header.cwh-shell', '.finpay-header', 'header.finpay-header',
     '.finpay-nav-wrapper', '.finpay-footer', 'footer.finpay-footer'].forEach(function (sel) {
      document.querySelectorAll(sel).forEach(function (el) {
        if (el.closest('.lp-ty-header') || el.closest('.lp-ty-footer')) return;
        if (el.classList.contains('lp-ty-header') || el.classList.contains('lp-ty-footer')) return;
        el.style.display = 'none';
        if (el.parentNode) el.parentNode.removeChild(el);
      });
    });
  }

  // ─── Read UTM params from URL + sessionStorage fallback ────
  function getAttribution() {
    var params = new URLSearchParams(window.location.search);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
    var attr = {};
    keys.forEach(function (k) { var v = params.get(k); if (v) attr[k] = v; });

    // Fallback: read from the originating LP's sessionStorage
    if (!attr.utm_source) {
      ['cw_lp_federal_checklist_attrib', 'cw_lp_10things_attrib'].forEach(function (storageKey) {
        try {
          var stored = sessionStorage.getItem(storageKey);
          if (stored) {
            var parsed = JSON.parse(stored) || {};
            keys.forEach(function (k) { if (parsed[k] && !attr[k]) attr[k] = parsed[k]; });
          }
        } catch (e) { /* ignore */ }
      });
    }
    return attr;
  }

  // ─── Display "we see you came from X" pill ────────────────
  function showSource(attr) {
    var src = attr.utm_source || (attr.fbclid ? 'facebook' : (attr.gclid ? 'google' : ''));
    if (!src) return;
    var map = {
      'facebook': 'Facebook', 'fb': 'Facebook', 'meta': 'Facebook',
      'google': 'Google', 'google_ads': 'Google Ads', 'googleads': 'Google Ads',
      'reddit': 'Reddit',
      'email': 'an email', 'newsletter': 'our newsletter',
      'linkedin': 'LinkedIn',
      'organic': 'search',
      'direct': 'direct'
    };
    var display = map[src.toLowerCase()] || src;
    var el = document.getElementById('lp-ty-source');
    if (el && display) {
      el.textContent = 'Thanks for visiting from ' + display + '.';
      el.classList.add('is-visible');
    }
  }

  // ─── Fire conversions ──────────────────────────────────────
  function fireConversions(attr) {
    // GA4 conversion (generate_lead) — duplicate of form-submit event, OK
    // for GA4 which dedupes; useful for platforms that key off URL.
    if (typeof gtag === 'function') {
      gtag('event', 'conversion_checklist_ty', {
        event_category: 'conversion',
        event_label: 'federal_checklist',
        value: 10,
        currency: 'USD',
        utm_source: attr.utm_source || '',
        utm_medium: attr.utm_medium || '',
        utm_campaign: attr.utm_campaign || '',
        utm_content: attr.utm_content || '',
        utm_term: attr.utm_term || ''
      });

      // Google Ads conversion — REPLACE 'AW-18091003527/CHECKLIST_LABEL' with the
      // actual conversion label from Google Ads > Tools > Conversions once created.
      gtag('event', 'conversion', {
        send_to: 'AW-18091003527/CHECKLIST_LABEL',
        value: 10,
        currency: 'USD'
      });
    }

    // Facebook Pixel — CompleteRegistration on TY (Lead already fired on submit)
    if (typeof fbq === 'function') {
      fbq('track', 'CompleteRegistration', {
        content_name: 'federal_checklist',
        content_category: 'Federal Benefits',
        status: 'completed',
        value: 10,
        currency: 'USD'
      });
    }

    // dataLayer for GTM
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'lp_ty_view',
      ty_page: 'federal_checklist',
      utm_source: attr.utm_source || '',
      utm_medium: attr.utm_medium || '',
      utm_campaign: attr.utm_campaign || '',
      value: 10,
      currency: 'USD'
    });

    // Reddit Pixel placeholder — uncomment once rdt pixel is installed
    // if (typeof rdt === 'function') { rdt('track', 'Lead'); }
  }

  function init() {
    killChrome();
    var attr = getAttribution();
    showSource(attr);
    fireConversions(attr);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  setTimeout(killChrome, 250);
  setTimeout(killChrome, 1500);
})();
</script>
