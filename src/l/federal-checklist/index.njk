{# ═══════════ JS: tracking, UTM capture, form, header-kill fallback ═══════════ #}
<script>
(function () {
  'use strict';

  // ─── Belt-and-suspenders header kill (defensive, in case CSS is overridden) ─
  function killChrome() {
    var killSelectors = [
      '.cwh-shell', '#cwhShell', 'header.cwh-shell',
      '.finpay-header', 'header.finpay-header', '.finpay-nav-wrapper',
      '.finpay-footer', 'footer.finpay-footer'
    ];
    killSelectors.forEach(function (sel) {
      document.querySelectorAll(sel).forEach(function (el) {
        // Don't nuke the LP's own in-page header/footer
        if (el.closest('.lp-mini-header') || el.closest('.lp-mini-footer')) return;
        if (el.classList.contains('lp-mini-header') || el.classList.contains('lp-mini-footer')) return;
        el.style.display = 'none';
        el.setAttribute('aria-hidden', 'true');
        if (el.parentNode) el.parentNode.removeChild(el);
      });
    });
  }

  var STORAGE_KEY = 'cw_lp_federal_checklist_attrib';

  // ─── UTM / attribution capture ─────────────────────────────
  function captureAttribution() {
    var params = new URLSearchParams(window.location.search);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
    var captured = {};
    try {
      var stored = sessionStorage.getItem(STORAGE_KEY);
      if (stored) captured = JSON.parse(stored) || {};
    } catch (e) { /* ignore */ }

    keys.forEach(function (k) {
      var v = params.get(k);
      if (v) captured[k] = v;
    });
    if (!captured.referrer && document.referrer) captured.referrer = document.referrer;

    try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(captured)); } catch (e) { /* ignore */ }

    keys.forEach(function (k) {
      var el = document.getElementById('lp-fc-' + k.replace('_', '-'));
      if (el && captured[k]) el.value = captured[k];
    });
    var refEl = document.getElementById('lp-fc-referrer');
    if (refEl) refEl.value = captured.referrer || '';
  }

  // ─── GA4 / Meta ViewContent on load ────────────────────────
  function trackPageView() {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'lp_federal_checklist_view' });
    if (typeof fbq === 'function') {
      fbq('track', 'ViewContent', {
        content_name: 'lp_federal_checklist',
        content_category: 'Federal Benefits'
      });
    }
  }

  // ─── Form submit ───────────────────────────────────────────
  function initForm() {
    var form = document.getElementById('lp-fc-form');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      // Honeypot — silently drop bots
      var honey = document.getElementById('lp-fc-website');
      if (honey && honey.value) return;

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      var submitBtn = document.getElementById('lp-fc-submit');
      var originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      var formData = new FormData(form);
      var data = {};
      formData.forEach(function (value, key) { data[key] = value; });

      fetch('/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function (r) { return r.json(); })
      .then(function (result) {
        if (result.success) {
          // GA4
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', {
              event_category: 'lead',
              event_label: 'federal_checklist_fb',
              value: 10
            });
          }
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: 'lp_federal_checklist_form_submit',
            form: 'checklist'
          });
          // Meta pixel Lead
          if (typeof fbq === 'function') {
            fbq('track', 'Lead', {
              content_name: 'lp_federal_checklist',
              content_category: 'Federal Benefits',
              value: 10,
              currency: 'USD'
            });
          }
          // Show inline success + redirect to TY page after 1.5s
          var formContent = form.closest('.lp-fc-form-card').querySelector('.lp-fc-form-content');
          var success = document.getElementById('lp-fc-success');
          if (formContent) formContent.style.display = 'none';
          if (success) success.classList.add('is-visible');
          setTimeout(function () {
            // Pass captured UTM params through to TY for conversion-tracking with attribution
            var utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
            var utmQs = utmKeys
              .map(function (k) {
                var el = document.getElementById('lp-fc-' + k.replace('_', '-'));
                return (el && el.value) ? encodeURIComponent(k) + '=' + encodeURIComponent(el.value) : null;
              })
              .filter(Boolean).join('&');
            window.location.href = '/l/federal-checklist/ty/' + (utmQs ? '?' + utmQs : '');
          }, 1500);
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          alert(result.error || 'Something went wrong. Please try again, or call us at (801) 210-2800.');
        }
      })
      .catch(function (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        console.error('Form submit error:', err);
        alert('Something went wrong. Please try again, or call us at (801) 210-2800.');
      });
    });
  }

  // Run immediately where possible (kill chrome before first paint of JS)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      killChrome();
      captureAttribution();
      trackPageView();
      initForm();
    });
  } else {
    killChrome();
    captureAttribution();
    trackPageView();
    initForm();
  }

  // Re-run kill after 250ms in case late scripts re-insert chrome
  setTimeout(killChrome, 250);
  setTimeout(killChrome, 1500);
})();
</script>
