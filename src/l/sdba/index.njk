  margin-bottom: 16px;
}
.lp-faq-title {
  font-size: 2.75rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  line-height: 1.1;
  margin-bottom: 12px;
}
.lp-faq-title-accent {
  color: var(--cool-horizon);
  font-style: italic;
}
.lp-faq-subtitle {
  font-size: 1.05rem;
  color: var(--slate-600);
  max-width: 620px;
  margin: 0 auto;
  line-height: 1.55;
}
.lp-faq-item {
  border-top: 1px solid rgba(22, 37, 60, 0.12);
}
.lp-faq-item:last-child { border-bottom: 1px solid rgba(22, 37, 60, 0.12); }
.lp-faq-item summary {
  list-style: none;
  cursor: pointer;
  padding: 22px 44px 22px 0;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--primary);
  font-family: var(--font-serif-display), serif;
  position: relative;
  line-height: 1.35;
}
.lp-faq-item summary::-webkit-details-marker { display: none; }
.lp-faq-item summary::after {
  content: '+';
  position: absolute;
  right: 4px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 1.75rem;
  color: var(--cool-horizon);
  font-weight: 300;
  transition: transform 0.2s ease;
}
.lp-faq-item[open] summary::after { content: '−'; }
.lp-faq-answer {
  padding: 0 0 22px 0;
  color: var(--slate-700);
  line-height: 1.65;
  font-size: 1rem;
}
.lp-faq-answer p { margin: 0 0 12px 0; }
.lp-faq-answer p:last-child { margin-bottom: 0; }
.lp-faq-answer ul {
  margin: 8px 0 12px 20px;
  padding: 0;
}
.lp-faq-answer li { margin-bottom: 6px; }
@media (max-width: 768px) {
  .lp-faq { padding: 64px 16px; }
  .lp-faq-title { font-size: 2rem; }
  .lp-faq-item summary { font-size: 1rem; padding-right: 36px; }
}

