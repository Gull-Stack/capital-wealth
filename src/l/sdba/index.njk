<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('#lp-lead-form');

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {};
      formData.forEach((value, key) => { data[key] = value; });

      if (validateForm()) {
        const submitBtn = form.querySelector('.lp-submit-btn');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'SECURING YOUR CALL...';
        submitBtn.disabled = true;

        fetch('/api/submit-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
          if (result.success) {
            window.location.href = '/l/sdba/ty/';
          } else {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
            alert('There was an error submitting your request. Please try again.');
          }
        })
        .catch(error => {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
          console.error('Error:', error);
          alert('There was an error submitting your request. Please try again.');
        });
      }
    });
  }

  function validateForm() {
    const requiredFields = form.querySelectorAll('input[required]');
    let isValid = true;

    requiredFields.forEach(field => {
      if (!field.value.trim()) {
        isValid = false;
        field.style.borderColor = '#DC2626';
        field.style.boxShadow = '0 0 0 2px rgba(220, 38, 38, 0.2)';
      } else {
        field.style.borderColor = '';
        field.style.boxShadow = '';
      }
    });

    return isValid;
  }
});
</script>
