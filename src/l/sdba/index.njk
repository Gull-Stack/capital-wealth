bodyClass: "landing-page"
permalink: "/l/sdba/"
---
<style>
/* Landing Page CSS - All vanilla CSS, no Tailwind */
/* Prefix all classes with 'lp-' for landing page */
.lp-landing-page,
.landing-page {
  --primary: #16253C;
  --secondary: #C7A356;
  --cool-horizon: #1B2A4A;
  --ink-black: #0F1A2A;
  --surface: #f8f9fb;
  --surface-container-low: #f3f4f6;
  --on-primary: #ffffff;
  --on-secondary: #0F1A2A;
  --slate-600: #475569;
  --slate-700: #334155;
  --slate-500: #64748b;
  font-family: var(--font-body), -apple-system, BlinkMacSystemFont, sans-serif;
}

/* Kill main padding that accounts for fixed header */
.landing-page main {
  padding-top: 0 !important;
}

/* Hide entire site header/nav on landing page */
.landing-page .finpay-header {
  display: none !important;
  height: 0 !important;
  min-height: 0 !important;
  max-height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  overflow: hidden !important;
  visibility: hidden !important;
  position: absolute !important;
}

.landing-page .finpay-header *,
.landing-page header *,
.landing-page .finpay-nav-wrapper,
.landing-page .finpay-nav,
.landing-page .finpay-nav-links,
.landing-page .finpay-nav-right,
.landing-page .finpay-nav-logo,
.landing-page .desktop-cta,
.landing-page .client-login-cta,
.landing-page .mobile-menu-btn {
  display: none !important;
  height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
}

/* Top Bar - Logo only */
.lp-topbar {
  background: white;
  padding: 24px 0;
  text-align: center;
  border-bottom: 1px solid #e5e7eb;
}

.lp-topbar img {
  height: 44px;
  width: auto;
}

/* Top announcement banner */
.lp-announce {
  background: var(--secondary);
  color: var(--ink-black);
  text-align: center;
  padding: 10px 16px;
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 0.01em;
}
.lp-announce a {
  color: var(--ink-black);
  text-decoration: underline;
  font-weight: 700;
  margin-left: 6px;
}
.lp-announce a:hover { opacity: 0.85; }

/* Hero Section — two-column: copy/CTA/trust left, video right */
.lp-hero {
  position: relative;
  display: block;
  padding: 48px 32px 56px;
  background: var(--surface-container-low);
  overflow: hidden;
}

.lp-hero-container {
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
  gap: 48px;
  align-items: center;
}

.lp-hero-left {
  text-align: left;
}

.lp-hero-right {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.lp-hero-right .lp-video-container {
  width: 100%;
  max-width: 640px;
}

/* Trust row: BBB + No-Obligation + Fiduciary */
.lp-trust-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24px;
  margin-top: 28px;
}
.lp-trust-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono), monospace;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate-700);
  font-weight: 700;
  line-height: 1.2;
}
.lp-trust-item svg {
  width: 22px;
  height: 22px;
  flex: 0 0 22px;
  color: var(--cool-horizon);
  fill: none;
  stroke: currentColor;
  stroke-width: 1.8;
}
.lp-trust-item img {
  height: 38px;
  width: auto;
  display: block;
}

/* Dedicated form section below the hero */
.lp-form-section {
  background: var(--surface);
  padding: 56px 24px 72px;
}
.lp-form-section-inner {
  max-width: 640px;
  margin: 0 auto;
}
.lp-form-section .lp-form-card {
  text-align: left;
}

@media (max-width: 900px) {
  .lp-hero { padding: 32px 20px 48px; }
  .lp-hero-container {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .lp-hero-left { text-align: left; }
}

.lp-federal-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--primary);
  color: #ffffff;
  padding: 8px 16px;
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 24px;
  border-radius: 4px;
}

.lp-federal-badge::before {
  content: '';
  width: 8px;
  height: 8px;
  background: var(--secondary);
  border-radius: 50%;
}

.lp-hero-title {
  font-size: 2.75rem;
  font-weight: bold;
  line-height: 1.1;
  margin-bottom: 20px;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
}

.lp-hero-title-accent {
  color: var(--cool-horizon);
  font-style: italic;
}

.lp-hero-description {
  font-size: 1.05rem;
  line-height: 1.55;
  max-width: 560px;
  color: var(--slate-600);
  margin-bottom: 28px;
}

.lp-video-container {
  position: relative;
  aspect-ratio: 16/9;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
  margin-bottom: 16px;
}

.lp-video-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.8);
}

.lp-play-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.2);
  cursor: pointer;
}

.lp-play-button {
  width: 80px;
  height: 80px;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.lp-play-button:hover {
  background: white;
  transform: scale(1.1);
}

.lp-play-button svg {
  width: 32px;
  height: 32px;
  fill: var(--primary);
  margin-left: 4px;
}

.lp-video-meta {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--slate-500);
  text-align: center;
}

/* Form Card */
.lp-form-card {
  max-width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 12px;
  padding: 40px;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
}

.lp-form-title {
  font-size: 1.75rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  margin-bottom: 8px;
}

.lp-form-subtitle {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  font-weight: 600;
  margin-bottom: 32px;
}

.lp-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.lp-form-group {
  margin-bottom: 20px;
}

.lp-form-label {
  display: block;
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--primary);
  margin-bottom: 8px;
  font-weight: 600;
}

.lp-form-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(22, 37, 60, 0.1);
  padding: 16px;
  border-radius: 8px;
  font-family: var(--font-body);
  font-size: 16px;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.lp-form-input::placeholder {
  color: #94a3b8;
}

.lp-form-input:focus {
  outline: none;
  border-color: var(--cool-horizon);
  box-shadow: 0 0 0 2px rgba(253, 210, 94, 0.2);
}

.lp-submit-btn {
  width: 100%;
  background: var(--primary);
  color: var(--on-primary);
  padding: 20px;
  border: none;
  border-radius: 8px;
  font-family: var(--font-body), sans-serif;
  font-weight: 700;
  font-size: 16px;
  cursor: pointer;
  transition: all 0.2s ease;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.lp-submit-btn:hover {
  background: var(--ink-black);
  transform: translateY(-1px);
}

.lp-submit-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

.lp-privacy-text {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  color: var(--slate-500);
  text-align: center;
  justify-content: center;
}

.lp-lock-icon {
  width: 12px;
  height: 12px;
  fill: var(--slate-500);
}

/* Authority Section */
.lp-authority {
  padding: 96px 24px;
  background: white;
}

.lp-authority-container {
  max-width: 1280px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 96px;
  align-items: center;
}

.lp-speaker-image-wrapper {
  position: relative;
}

.lp-speaker-image {
  border-radius: 12px;
  overflow: hidden;
  filter: grayscale(0.3);
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
}

.lp-speaker-image img {
  width: 100%;
  height: auto;
  display: block;
}

.lp-book-card {
  position: absolute;
  bottom: -24px;
  right: -24px;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(24px);
  padding: 24px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  max-width: 220px;
}

.lp-book-badge {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  font-weight: 600;
  margin-bottom: 8px;
}

.lp-book-title {
  font-family: var(--font-serif-display), serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--primary);
  line-height: 1.3;
}

.lp-authority-content .lp-eyebrow {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  margin-bottom: 16px;
  font-weight: 600;
}

.lp-authority-headline {
  font-size: 3.5rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  margin-bottom: 32px;
  line-height: 1.1;
}

.lp-authority-headline-accent {
  color: var(--cool-horizon);
  font-style: italic;
}

.lp-pull-quote {
  font-size: 1.5rem;
  font-style: italic;
  font-family: var(--font-serif-display), serif;
  color: var(--slate-700);
  line-height: 1.4;
  margin-bottom: 48px;
  position: relative;
  padding-left: 32px;
}

.lp-pull-quote::before {
  content: '"';
  position: absolute;
  left: -8px;
  top: -16px;
  font-size: 4rem;
  color: rgba(22, 37, 60, 0.1);
  font-family: var(--font-serif-display), serif;
  line-height: 1;
}

.lp-credentials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.lp-credential {
  text-align: left;
}

.lp-credential-label {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  font-weight: 600;
  margin-bottom: 8px;
}

.lp-credential-text {
  color: var(--slate-600);
  font-size: 14px;
  line-height: 1.4;
}

/* Fiduciary Protocol Section */
.lp-fiduciary {
  padding: 96px 24px;
  background: #f3f4f6;
}

.lp-fiduciary-container {
  max-width: 1280px;
  margin: 0 auto;
  text-align: center;
}

.lp-fiduciary .lp-eyebrow {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  margin-bottom: 16px;
  font-weight: 600;
}

.lp-fiduciary-headline {
  font-size: 3rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  margin-bottom: 24px;
  line-height: 1.1;
}

.lp-fiduciary-headline-accent {
  color: var(--cool-horizon);
  font-style: italic;
}

.lp-fiduciary-subtext {
  font-size: 1.25rem;
  color: var(--slate-600);
  line-height: 1.5;
  max-width: 800px;
  margin: 0 auto 64px;
}

.lp-pillars-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24px;
  margin-bottom: 48px;
}

.lp-pillar-card {
  background: white;
  padding: 32px 24px;
  border-radius: 12px;
  border: 1px solid rgba(22, 37, 60, 0.1);
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
}

.lp-pillar-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
}

.lp-pillar-icon {
  width: 48px;
  height: 48px;
  margin: 0 auto 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(87, 165, 244, 0.1);
  border-radius: 50%;
}

.lp-pillar-icon svg {
  width: 24px;
  height: 24px;
  fill: var(--cool-horizon);
}

.lp-pillar-title {
  font-size: 1.25rem;
  font-family: var(--font-serif-display), serif;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 12px;
}

.lp-pillar-description {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--slate-500);
}

.lp-fiduciary-banner {
  background: var(--primary);
  color: var(--on-primary);
  padding: 24px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
}

.lp-shield-icon {
  width: 32px;
  height: 32px;
  fill: var(--secondary);
}

.lp-banner-text {
  font-size: 1rem;
  font-weight: 600;
}

/* Precision Benefits Section */
.lp-precision {
  padding: 96px 24px;
  background: white;
}

.lp-precision-container {
  max-width: 1280px;
  margin: 0 auto;
}

.lp-precision .lp-eyebrow {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  margin-bottom: 16px;
  font-weight: 600;
  text-align: center;
}

.lp-precision-headline {
  font-size: 3rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  margin-bottom: 64px;
  line-height: 1.1;
  text-align: center;
}

.lp-precision-headline-accent {
  color: var(--cool-horizon);
  font-style: italic;
}

.lp-precision-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
}

.lp-precision-card {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(22, 37, 60, 0.1);
  border-radius: 12px;
  padding: 40px;
  position: relative;
  overflow: hidden;
}

.lp-precision-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: var(--cool-horizon);
}

.lp-card-number {
  position: absolute;
  top: 16px;
  right: 16px;
  font-family: var(--font-mono), monospace;
  font-size: 2rem;
  font-weight: 300;
  color: rgba(22, 37, 60, 0.1);
}

.lp-precision-card-title {
  font-size: 1.5rem;
  font-family: var(--font-serif-display), serif;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 24px;
}

.lp-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid rgba(22, 37, 60, 0.1);
}

.lp-stat-label {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--slate-500);
}

.lp-stat-value {
  font-weight: 600;
  color: var(--primary);
}

.lp-stat-callout {
  background: rgba(87, 165, 244, 0.1);
  border-left: 4px solid var(--cool-horizon);
  padding: 20px;
  margin-top: 24px;
  border-radius: 0 8px 8px 0;
}

.lp-stat-callout-text {
  font-size: 14px;
  color: var(--slate-600);
  line-height: 1.5;
}

.lp-stat-highlight {
  color: var(--primary);
  font-weight: 600;
}

.lp-fegli-bars {
  display: flex;
  align-items: end;
  gap: 8px;
  height: 120px;
  margin: 24px 0;
}

.lp-fegli-bar {
  flex: 1;
  background: var(--cool-horizon);
  border-radius: 4px 4px 0 0;
  position: relative;
}

.lp-fegli-bar:nth-child(5) {
  background: var(--secondary);
}

.lp-fegli-bar:nth-child(6) {
  background: #dc2626;
}

.lp-fegli-bar-label {
  position: absolute;
  bottom: -20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 10px;
  font-family: var(--font-mono), monospace;
  color: var(--slate-500);
  white-space: nowrap;
}

.lp-risk-factor {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #dc2626;
  font-weight: 600;
  text-align: center;
  margin-top: 16px;
}



/* Footer */
.lp-footer {
  background: white;
  padding: 48px 24px 32px;
  border-top: 1px solid rgba(22, 37, 60, 0.1);
}

.lp-footer-container {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 24px;
}

.lp-footer-logo img {
  height: 32px;
  width: auto;
}

.lp-footer-links {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
}

.lp-footer-link {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--slate-500);
  text-decoration: none;
  transition: color 0.2s ease;
}

.lp-footer-link:hover {
  color: var(--primary);
}

.lp-footer-copyright {
  font-size: 14px;
  color: var(--slate-500);
  text-align: center;
  width: 100%;
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid rgba(22, 37, 60, 0.1);
}

/* Mobile Responsive */
@media (max-width: 768px) {
  .lp-hero-container {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  
  .lp-hero-title {
    font-size: 2.5rem;
  }
  
  .lp-form-row {
    grid-template-columns: 1fr;
  }
  
  .lp-authority-container {
    grid-template-columns: 1fr;
    gap: 48px;
  }
  
  .lp-book-card {
    position: relative;
    bottom: auto;
    right: auto;
    margin-top: 24px;
    max-width: 100%;
  }
  
  .lp-credentials-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  
  .lp-pillars-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .lp-precision-cards {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  
  .lp-fiduciary-headline,
  .lp-precision-headline,
  .lp-authority-headline {
    font-size: 2rem;
  }
  
  .lp-footer-container {
    flex-direction: column;
    text-align: center;
  }
  
  .lp-footer-links {
    justify-content: center;
  }
}

/* Hide main site footer on landing page — we have our own .lp-footer */
.landing-page .finpay-footer,
.landing-page footer.finpay-footer {
  display: none !important;
  height: 0 !important;
  max-height: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  overflow: hidden !important;
  visibility: hidden !important;
}


/* Hide site-wide gov-contractor banner on landing page */
.landing-page .gov-bar {
