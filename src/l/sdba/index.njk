/* =========================================================
   Calculator Section
   ========================================================= */
.lp-calc {
  background: var(--surface);
  padding: 72px 24px;
  border-top: 1px solid #e5e7eb;
  border-bottom: 1px solid #e5e7eb;
}
.lp-calc-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.lp-calc-header {
  text-align: center;
  margin-bottom: 32px;
}
.lp-calc-eyebrow {
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--cool-horizon);
  font-weight: 600;
  margin-bottom: 12px;
}
.lp-calc-title {
  font-size: 2.25rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  line-height: 1.15;
  margin-bottom: 12px;
}
.lp-calc-subtitle {
  font-size: 1.05rem;
  color: var(--slate-600);
  max-width: 680px;
  margin: 0 auto;
  line-height: 1.55;
}
.lp-calc-card {
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 20px 50px rgba(15, 26, 42, 0.08);
  border: 1px solid rgba(22, 37, 60, 0.08);
  padding: 40px;
  display: grid;
  grid-template-columns: minmax(260px, 360px) 1fr;
  gap: 40px;
  align-items: start;
}
.lp-calc-form .lp-calc-label {
  display: block;
  font-family: var(--font-mono), monospace;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--primary);
  font-weight: 700;
  margin-top: 18px;
  margin-bottom: 6px;
}
.lp-calc-form .lp-calc-label:first-child { margin-top: 0; }
.lp-calc-form .lp-calc-input {
  width: 100%;
  padding: 14px 14px;
  border-radius: 10px;
  border: 1px solid rgba(22, 37, 60, 0.2);
  background: #fff;
  font-size: 16px;
  font-family: var(--font-body), sans-serif;
  color: var(--primary);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}
.lp-calc-form .lp-calc-input:focus {
  outline: none;
  border-color: var(--secondary);
  box-shadow: 0 0 0 3px rgba(199, 163, 86, 0.15);
}
.lp-calc-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 24px;
}
.lp-calc-btn {
  display: block;
  width: 100%;
  padding: 14px 18px;
  border: none;
  border-radius: 10px;
  font-family: var(--font-body), sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  text-align: center;
  transition: all 0.2s ease;
}
.lp-calc-btn-primary {
  background: var(--primary);
  color: #fff;
}
.lp-calc-btn-primary:hover { background: var(--ink-black); transform: translateY(-1px); }
.lp-calc-btn-accent {
  background: var(--secondary);
  color: var(--ink-black);
}
.lp-calc-btn-accent:hover { filter: brightness(1.05); transform: translateY(-1px); }
.lp-calc-chart-col {
  display: flex;
  flex-direction: column;
}
.lp-calc-headline {
  font-size: 1.75rem;
  font-family: var(--font-serif-display), serif;
  color: var(--primary);
  text-align: center;
  min-height: 44px;
  margin-bottom: 10px;
  line-height: 1.25;
}
.lp-calc-headline .lp-calc-highlight {
  color: var(--secondary);
  font-weight: 700;
  font-style: italic;
}
.lp-calc-chart-wrap {
  position: relative;
  width: 100%;
  height: 340px;
}
.lp-calc-disclaimer {
  margin-top: 24px;
  font-size: 11px;
  line-height: 1.5;
  color: var(--slate-500);
  text-align: center;
  max-width: 900px;
  margin-left: auto;
  margin-right: auto;
}
@media (max-width: 900px) {
  .lp-calc { padding: 48px 16px; }
  .lp-calc-card {
    grid-template-columns: 1fr;
    gap: 28px;
    padding: 28px;
  }
  .lp-calc-title { font-size: 1.75rem; }
  .lp-calc-chart-wrap { height: 280px; }
}

