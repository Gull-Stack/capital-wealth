<script>
document.addEventListener('DOMContentLoaded', function() {
  const form = document.querySelector('#lp-lead-form');

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {};
      formData.forEach((value, key) => { data[key] = value; });

      if (validateForm()) {
        const submitBtn = form.querySelector('.lp-submit-btn');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'SECURING YOUR CALL...';
        submitBtn.disabled = true;

        fetch('/api/submit-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(result => {
          if (result.success) {
            window.location.href = '/l/sdba/ty/';
          } else {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
            alert('There was an error submitting your request. Please try again.');
          }
        })
        .catch(error => {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
          console.error('Error:', error);
          alert('There was an error submitting your request. Please try again.');
        });
      }
    });
  }

  function validateForm() {
    const requiredFields = form.querySelectorAll('input[required]');
    let isValid = true;

    requiredFields.forEach(field => {
      if (!field.value.trim()) {
        isValid = false;
        field.style.borderColor = '#DC2626';
        field.style.boxShadow = '0 0 0 2px rgba(220, 38, 38, 0.2)';
      } else {
        field.style.borderColor = '';
        field.style.boxShadow = '';
      }
    });

    return isValid;
  }
});
</script>

<!-- Chart.js for calculator -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>

<!-- SDBA Advantage Calculator -->
<script>
(function() {
  // Helpers
  function parseCurrency(val) {
    if (val === null || val === undefined) return 0;
    var cleaned = String(val).replace(/[^0-9.]/g, '');
    var n = parseFloat(cleaned);
    return isFinite(n) ? Math.max(0, Math.round(n)) : 0;
  }
  function fmtCurrency(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  var ageEl, salaryEl, balanceEl, retireEl, headlineEl, runBtn, canvas, chart;

  function setupCurrencyFormatting(el) {
    el.addEventListener('blur', function() {
      var v = parseCurrency(el.value);
      el.value = v ? fmtCurrency(v) : '';
    });
    el.addEventListener('focus', function() {
      el.value = String(parseCurrency(el.value) || '');
    });
  }

  function project(balance, ages, salary, rate) {
    var contributionRate = 0.078 + 0.046; // 12.4%
    var salaryGrowth = 0.03;
    var monthlyRate = Math.pow(1 + rate, 1 / 12);
    var monthlyFactor = Math.pow(monthlyRate, 12);
    var contribMultiplier = (monthlyFactor - 1) / (monthlyRate - 1);

    var total = balance;
    var out = [balance];
    for (var i = 0; i < ages.length - 1; i++) {
      var yearsFromNow = i;
      var thisYearSalary = salary * Math.pow(1 + salaryGrowth, yearsFromNow);
      var thisYearContrib = thisYearSalary * contributionRate;
      total = total * monthlyFactor + (thisYearContrib / 12) * contribMultiplier;
      out.push(Math.round(Math.max(0, total)));
    }
    return out;
  }

  function renderChart(ages, withSdba, defaultPlan) {
    if (!window.Chart) {
      // Chart.js not ready — poll briefly
      var t = setInterval(function() {
        if (window.Chart) {
          clearInterval(t);
          renderChart(ages, withSdba, defaultPlan);
        }
      }, 150);
      return;
    }
    if (chart) chart.destroy();
    chart = new Chart(canvas.getContext('2d'), {
      type: 'line',
      data: {
        labels: ages,
        datasets: [
          {
            label: 'Advised SDBA (+1%)',
            data: withSdba,
            borderColor: '#C7A356',
            backgroundColor: 'rgba(199,163,86,0.12)',
            borderWidth: 3,
            pointRadius: 0,
            tension: 0.25,
            fill: true
          },
          {
            label: 'Default 401k (S&P 500, 7%)',
            data: defaultPlan,
            borderColor: '#16253C',
            backgroundColor: 'rgba(22,37,60,0.04)',
            borderWidth: 3,
            pointRadius: 0,
            tension: 0.25,
            fill: true
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              color: '#16253C',
              boxWidth: 16,
              boxHeight: 10,
              padding: 14,
              font: { size: 12, weight: '600' }
            }
          },
          tooltip: {
            callbacks: {
              title: function(items) { return 'Age ' + items[0].label; },
              label: function(ctx) {
                return ctx.dataset.label + ': ' + fmtCurrency(ctx.parsed.y);
              }
            }
          }
        },
        scales: {
          y: {
            ticks: {
              callback: function(v) {
                if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
                if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
                return '$' + v;
              },
              color: '#64748b'
            },
            grid: { color: 'rgba(22,37,60,0.08)' }
          },
          x: {
            ticks: { color: '#64748b', maxTicksLimit: 8 },
            grid: { display: false }
          }
        }
      }
    });
  }

  function run() {
    var age = parseInt(ageEl.value, 10) || 0;
    var retire = parseInt(retireEl.value, 10) || 65;
    if (retire < 50) retire = 50;
    if (retire > 80) retire = 80;
    var salary = parseCurrency(salaryEl.value);
    var balance = parseCurrency(balanceEl.value);

    if (!age || age < 18 || age >= retire || salary <= 0) {
      headlineEl.innerHTML = 'Enter your details to see your SDBA advantage.';
      if (chart) { chart.destroy(); chart = null; }
      return;
    }

    var years = retire - age;
    var ages = [];
    for (var i = 0; i <= years; i++) ages.push(age + i);

    var rDefault = 0.07;   // S&P 500 long-run average
    var rAdvised = 0.08;   // 1% better
    var defaultPlan = project(balance, ages, salary, rDefault);
    var withSdba = project(balance, ages, salary, rAdvised);

    var diff = withSdba[withSdba.length - 1] - defaultPlan[defaultPlan.length - 1];
    headlineEl.innerHTML =
      'Could <span class="lp-calc-highlight">' + fmtCurrency(diff) + '</span> more change your retirement?';

    renderChart(ages, withSdba, defaultPlan);
  }

  function init() {
    ageEl = document.getElementById('cw-calc-age');
    salaryEl = document.getElementById('cw-calc-salary');
    balanceEl = document.getElementById('cw-calc-balance');
    retireEl = document.getElementById('cw-calc-retire');
    headlineEl = document.getElementById('cw-calc-headline');
    runBtn = document.getElementById('cw-calc-run');
    canvas = document.getElementById('cw-calc-chart');
    if (!canvas) return;

    setupCurrencyFormatting(salaryEl);
    setupCurrencyFormatting(balanceEl);

    runBtn.addEventListener('click', run);
    [ageEl, salaryEl, balanceEl, retireEl].forEach(function(el) {
      el.addEventListener('change', run);
      el.addEventListener('keyup', function(e) {
        if (e.key === 'Enter') run();
      });
    });

    // Initial render
    setTimeout(run, 250);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
