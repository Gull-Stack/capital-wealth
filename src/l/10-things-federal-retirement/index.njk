  max-width: 720px;
  margin: 0 auto;
}
.lp-process-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.lp-process-card {
  background: var(--cw-bg-subtle);
  border-radius: 12px;
  padding: 32px;
  border-top: 4px solid var(--cw-fed-red);
}
.lp-process-step {
  font-family: var(--font-mono, monospace);
  font-size: 0.8rem;
  color: var(--cw-fed-red);
  font-weight: 700;
  letter-spacing: 0.15em;
  margin-bottom: 12px;
}
.lp-process-card h3 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--cw-fed-blue);
  margin: 0 0 12px;
}
.lp-process-card p {
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--cw-muted);
  margin: 0;
}

/* ─── FAQ ───────────────────────────────────────────────────── */
.lp-faq {
  padding: 80px 32px;
  background: var(--cw-bg-subtle);
}
.lp-faq-inner {
  max-width: 820px;
  margin: 0 auto;
}
.lp-faq-header {
  text-align: center;
  margin-bottom: 40px;
}
.lp-faq h2 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--cw-fed-blue);
  line-height: 1.2;
  margin: 0;
}
.lp-faq-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.lp-faq-item {
  background: var(--cw-white);
  border: 1px solid var(--cw-border);
  border-radius: 10px;
  margin-bottom: 12px;
  overflow: hidden;
}
.lp-faq-item[open] { border-color: var(--cw-fed-red); }
.lp-faq-summary {
  padding: 20px 24px;
  cursor: pointer;
  font-weight: 600;
  font-size: 1.05rem;
  color: var(--cw-fed-blue);
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  line-height: 1.4;
}
.lp-faq-summary::-webkit-details-marker { display: none; }
.lp-faq-summary::after {
  content: "+";
  font-size: 1.5rem;
  color: var(--cw-fed-red);
  font-weight: 400;
  flex-shrink: 0;
  transition: transform 0.2s ease;
}
.lp-faq-item[open] .lp-faq-summary::after {
  content: "−";
}
.lp-faq-summary:focus-visible {
  outline: 3px solid var(--cw-fed-red);
  outline-offset: -3px;
}
.lp-faq-answer {
  padding: 0 24px 20px;
  color: var(--cw-ink);
  line-height: 1.65;
  font-size: 1rem;
  margin: 0;
}

/* ─── FINAL CTA ─────────────────────────────────────────────── */
.lp-final {
  background: var(--cw-fed-blue);
  color: var(--cw-white);
  padding: 80px 32px;
  text-align: center;
}
.lp-final-inner { max-width: 720px; margin: 0 auto; }
.lp-final h2 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--cw-white);
  line-height: 1.15;
  margin: 0 0 20px;
}
.lp-final p {
  font-size: 1.15rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
  margin: 0 0 32px;
}
.lp-final-cta-row {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.lp-final-reassure {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 24px;
}

/* ─── DISCLAIMER ────────────────────────────────────────────── */
.lp-disclaimer {
  background: var(--cw-fed-blue-dark);
  color: rgba(255, 255, 255, 0.7);
  padding: 32px 32px 48px;
  font-size: 0.85rem;
  line-height: 1.6;
  text-align: center;
}
.lp-disclaimer p {
  max-width: 900px;
  margin: 0 auto;
}

/* ─── MOBILE ────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .lp-hero-inner { grid-template-columns: 1fr; gap: 40px; }
  .lp-hero h1 { font-size: 2.5rem; }
  .lp-ann-inner { grid-template-columns: 1fr; gap: 24px; }
  .lp-ann-photo { max-width: 280px; }
  .lp-why-grid,
  .lp-process-grid { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .lp-hero { padding: 40px 20px 56px; }
  .lp-hero h1 { font-size: 2rem; }
  .lp-hero-subhead { font-size: 1rem; }
  .lp-trust { padding: 20px; }
  .lp-trust-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .lp-setup, .lp-ten, .lp-ann, .lp-why, .lp-process, .lp-faq, .lp-final, .lp-form-wrap { padding: 56px 20px; }
  .lp-midcta { padding: 48px 20px; }
  .lp-setup h2, .lp-ten-header h2, .lp-ann-details h2, .lp-why h2, .lp-process h2, .lp-faq h2, .lp-final h2, .lp-midcta h2 {
    font-size: 1.75rem;
  }
  .lp-ten-item { grid-template-columns: 1fr; padding: 24px; gap: 16px; }
  .lp-ten-body h3 { font-size: 1.25rem; }
  .lp-form { padding: 24px; }
  .lp-form-row { grid-template-columns: 1fr; }
  .lp-hero-cta-row,
  .lp-final-cta-row { flex-direction: column; align-items: stretch; }
  .lp-hero-cta-row > *,
  .lp-final-cta-row > * { width: 100%; }
}

/* ─── A11Y ──────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .lp-ten-item,
  .lp-btn-primary,
  .lp-btn-ghost { transition: none !important; transform: none !important; }
}
</style>

