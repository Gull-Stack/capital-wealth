   palette off this page.
   ══════════════════════════════════════════════════════════════ */

.lp-10-things {
  --cw-fed-red: #B31942;
  --cw-fed-red-dark: #9a1538;
  --cw-fed-blue: #0A3161;
  --cw-fed-blue-dark: #081f3f;
  --cw-fed-blue-ink: #0F2243;
  --cw-white: #FFFFFF;
  --cw-bg-subtle: #f8f9fb;
