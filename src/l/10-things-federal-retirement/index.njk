{# ═══════════ JS: tracking, UTM capture, form, accordion ═══════════ #}
<script>
(function () {
  'use strict';

  var STORAGE_KEY = 'cw_lp_10things_attrib';

  // ─── UTM / attribution capture ─────────────────────────────
  function captureAttribution() {
    var params = new URLSearchParams(window.location.search);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
    var captured = {};

    // Start from stored (sessionStorage) so nav between sections doesn't lose anchors from initial load
    try {
      var stored = sessionStorage.getItem(STORAGE_KEY);
      if (stored) captured = JSON.parse(stored) || {};
    } catch (e) { /* ignore */ }

    keys.forEach(function (k) {
      var v = params.get(k);
      if (v) captured[k] = v;
    });

    if (!captured.referrer && document.referrer) captured.referrer = document.referrer;

    try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(captured)); } catch (e) { /* ignore */ }

    // Stamp hidden inputs
    keys.forEach(function (k) {
      var el = document.getElementById('lp-' + k.replace('_', '-'));
      if (el && captured[k]) el.value = captured[k];
    });
    var refEl = document.getElementById('lp-referrer');
    if (refEl) refEl.value = captured.referrer || '';
    var srcEl = document.getElementById('lp-submitted-from');
    if (srcEl) srcEl.value = window.location.pathname;
  }

  // ─── GA4 / dataLayer + Meta ViewContent on load ────────────
  function trackPageView() {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'lp_10things_view' });
    if (typeof fbq === 'function') {
      fbq('track', 'ViewContent', {
        content_name: 'lp_10things',
        content_category: 'Federal Benefits'
      });
    }
  }

  // ─── 50% scroll tracker (IntersectionObserver) ─────────────
  function trackScrollDepth() {
    var sentinel = document.getElementById('lp-scroll-sentinel');
    if (!sentinel || !('IntersectionObserver' in window)) return;
    var fired = false;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting && !fired) {
          fired = true;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'lp_10things_scroll_50' });
          io.disconnect();
        }
      });
    });
    io.observe(sentinel);
  }

  // ─── CTA click tracking ────────────────────────────────────
  function trackCtaClicks() {
    document.querySelectorAll('[data-cta]').forEach(function (el) {
      el.addEventListener('click', function () {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'lp_10things_cta_click',
          cta: el.getAttribute('data-cta')
        });
      });
    });
  }

  // ─── Form variant switching ────────────────────────────────
  function initFormTabs() {
    var tabReview = document.getElementById('tab-review');
    var tabChecklist = document.getElementById('tab-checklist');
    var reviewOnlyBlock = document.querySelector('.lp-form-review-only');
    var reviewOnlyInputs = reviewOnlyBlock ? reviewOnlyBlock.querySelectorAll('input, select') : [];
    var variantInput = document.getElementById('lp-variant');
    var leadTypeInput = document.getElementById('lp-lead-type');
    var headingReview = document.getElementById('form-heading-review');
    var subReview = document.getElementById('form-sub-review');
    var headingChecklist = document.getElementById('form-heading-checklist');
    var subChecklist = document.getElementById('form-sub-checklist');
    var submitReview = document.querySelector('[data-submit-text="review"]');
    var submitChecklist = document.querySelector('[data-submit-text="checklist"]');
    var phoneInput = document.getElementById('lp-phone');

    function setVariant(variant) {
      var isReview = variant === 'review';
      if (tabReview) tabReview.setAttribute('aria-selected', isReview ? 'true' : 'false');
      if (tabChecklist) tabChecklist.setAttribute('aria-selected', isReview ? 'false' : 'true');
      if (reviewOnlyBlock) reviewOnlyBlock.style.display = isReview ? '' : 'none';
      // Phone is required for the review variant only
      if (phoneInput) {
        if (isReview) phoneInput.setAttribute('required', 'required');
        else phoneInput.removeAttribute('required');
      }
      if (headingReview) headingReview.hidden = !isReview;
      if (subReview) subReview.hidden = !isReview;
      if (headingChecklist) headingChecklist.hidden = isReview;
      if (subChecklist) subChecklist.hidden = isReview;
      if (submitReview) submitReview.hidden = !isReview;
      if (submitChecklist) submitChecklist.hidden = isReview;
      if (variantInput) variantInput.value = variant;
      if (leadTypeInput) leadTypeInput.value = '10things-' + variant;
    }

    if (tabReview) tabReview.addEventListener('click', function () { setVariant('review'); });
    if (tabChecklist) tabChecklist.addEventListener('click', function () { setVariant('checklist'); });

    // Default: review, but switch to checklist when arriving via #get-checklist
    function syncVariantFromHash() {
      if (window.location.hash === '#get-checklist') setVariant('checklist');
    }
    window.addEventListener('hashchange', syncVariantFromHash);
    syncVariantFromHash();
  }

  // ─── Form submit ───────────────────────────────────────────
  function initForm() {
    var form = document.getElementById('lp-10things-form');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var variantInput = document.getElementById('lp-variant');
      var variant = variantInput ? variantInput.value : 'review';
      var submitBtn = document.getElementById('lp-form-submit');

      // Native validation first
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitBtn.disabled = true;
      var originalHtml = submitBtn.innerHTML;
      submitBtn.innerHTML = 'Sending…';

      var formData = new FormData(form);
      var data = {};
      formData.forEach(function (value, key) { data[key] = value; });

      fetch('/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function (r) { return r.json(); })
      .then(function (result) {
        if (result.success) {
          // dataLayer
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: 'lp_10things_form_submit',
            form: variant
          });
          // Meta pixel Lead
          if (typeof fbq === 'function') {
            fbq('track', 'Lead', {
              content_name: 'lp_10things',
              content_category: variant,
              value: variant === 'review' ? 50 : 10,
              currency: 'USD'
            });
          }
          var dest = variant === 'review'
            ? '/l/10-things-federal-retirement/ty-review/'
            : '/l/10-things-federal-retirement/ty-checklist/';
          window.location.href = dest;
        } else {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalHtml;
          alert(result.error || 'Something went wrong. Please try again.');
        }
      })
      .catch(function (err) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalHtml;
        console.error('Form submit error:', err);
        alert('Something went wrong. Please try again, or call us at 801.210.2800.');
      });
    });
  }

  // ─── Smooth scroll for same-page anchors ───────────────────
  function initSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach(function (a) {
      a.addEventListener('click', function (e) {
        var id = a.getAttribute('href');
        if (id.length < 2) return;
        var el = document.querySelector(id);
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.pushState(null, '', id);
          // Dispatch hashchange so form-variant sync runs
          window.dispatchEvent(new HashChangeEvent('hashchange'));
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    captureAttribution();
    trackPageView();
    trackScrollDepth();
    trackCtaClicks();
    initFormTabs();
    initForm();
    initSmoothScroll();
  });
})();
</script>
