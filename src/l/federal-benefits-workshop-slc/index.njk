<script>
  (function () {
    'use strict';

    // Analytics shim — replace with site's existing tracker (gtag, segment, etc.)
    function track(event, payload) {
      try {
        if (typeof window.dataLayer !== 'undefined') {
          window.dataLayer.push(Object.assign({ event: event }, payload || {}));
        }
        if (typeof window.gtag === 'function') {
          window.gtag('event', event, payload || {});
        }
      } catch (e) { /* swallow */ }
    }

    // CTA tracking
    document.querySelectorAll('a.btn-red[data-cta]').forEach(function (el) {
      el.addEventListener('click', function () {
        track('cta_click', { source: el.dataset.cta, page: 'ogden-may-2026' });
      });
    });

    // Guest progressive disclosure
    var guestToggle = document.getElementById('guest-toggle');
    var guestFields = document.getElementById('guest-fields');
    if (guestToggle && guestFields) {
      guestToggle.addEventListener('click', function () {
        var expanded = guestToggle.getAttribute('aria-expanded') === 'true';
        guestToggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          guestFields.setAttribute('hidden', '');
          guestToggle.textContent = 'Add their info →';
        } else {
          guestFields.removeAttribute('hidden');
          guestToggle.textContent = 'Hide guest info';
          var firstGuest = guestFields.querySelector('input');
          if (firstGuest) firstGuest.focus();
        }
      });
    }

    // Phone formatter — light touch, allows international too
    var phoneInput = document.getElementById('f-phone');
    if (phoneInput) {
      phoneInput.addEventListener('input', function () {
        var digits = phoneInput.value.replace(/\D/g, '').slice(0, 10);
        if (digits.length === 10) {
          phoneInput.value = '(' + digits.slice(0,3) + ') ' + digits.slice(3,6) + '-' + digits.slice(6);
        } else if (digits.length >= 7) {
          phoneInput.value = '(' + digits.slice(0,3) + ') ' + digits.slice(3,6) + '-' + digits.slice(6);
        } else if (digits.length >= 4) {
          phoneInput.value = '(' + digits.slice(0,3) + ') ' + digits.slice(3);
        } else {
          phoneInput.value = digits;
        }
      });
    }

    // Form validation + submission
    var form = document.getElementById('rsvp-form');
    var rsvpRoot = document.getElementById('rsvp');
    var submitBtn = document.getElementById('rsvp-submit');
    var banner = document.getElementById('form-banner');

    function setError(input, hasError) {
      var field = input.closest('.field');
      if (!field) return;
      field.classList.toggle('error', !!hasError);
    }

    function clearErrors() {
      form.querySelectorAll('.field').forEach(function (f) { f.classList.remove('error'); });
      rsvpRoot.classList.remove('has-error');
    }

    function validate() {
      var first = document.getElementById('f-first');
      var last  = document.getElementById('f-last');
      var email = document.getElementById('f-email');
      var phone = document.getElementById('f-phone');

      var ok = true;
      setError(first, !first.value.trim()); if (!first.value.trim()) ok = false;
      setError(last,  !last.value.trim());  if (!last.value.trim())  ok = false;

      var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim());
      setError(email, !emailOk); if (!emailOk) ok = false;

      var phoneDigits = (phone.value || '').replace(/\D/g, '');
      var phoneOk = phoneDigits.length === 10;
      setError(phone, !phoneOk); if (!phoneOk) ok = false;

      return ok;
    }

    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearErrors();

        if (!validate()) {
          rsvpRoot.classList.add('has-error');
          banner.textContent = 'Please fix the highlighted fields and try again.';
          var firstError = form.querySelector('.field.error input');
          if (firstError) firstError.focus();
          return;
        }

        submitBtn.setAttribute('disabled', '');
        submitBtn.textContent = 'Reserving…';

        try {
          var qp = new URLSearchParams(window.location.search);
          ['utm_source','utm_medium','utm_content','utm_term'].forEach(function (k) {
            var el = document.getElementById(k);
            if (el && qp.get(k)) el.value = qp.get(k);
          });
          var refEl = document.getElementById('referrer');
          if (refEl) refEl.value = document.referrer || '';
        } catch (_) {}

        var data = new FormData(form);
        var payload = {};
        data.forEach(function (v, k) { payload[k] = v; });
        payload.name = ((payload.firstName || '') + ' ' + (payload.lastName || '')).trim();

        track('rsvp_submit', { source: 'federal-benefits-workshop-slc' });

        fetch('/api/submit-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (result) {
          if (result && result.success) {
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'generate_lead', {
                event_category: 'lead',
                event_label: 'federal_workshop_slc_may20',
                value: 1
              });
            }
            if (typeof window.fbq === 'function') {
              window.fbq('track', 'Lead', {
                content_name: 'Federal Workshop SLC May 20',
                content_category: 'Federal Benefits'
              });
            }
            window.location.href = '/l/federal-benefits-workshop-slc/ty/';
          } else {
            submitBtn.removeAttribute('disabled');
            submitBtn.textContent = 'Confirm Registration';
            rsvpRoot.classList.add('has-error');
            banner.textContent = 'Something went wrong submitting your registration. Please try again, or call (801) 210-2800.';
          }
        })
        .catch(function (err) {
          submitBtn.removeAttribute('disabled');
          submitBtn.textContent = 'Confirm Registration';
          rsvpRoot.classList.add('has-error');
          banner.textContent = 'Something went wrong submitting your registration. Please try again, or call (801) 210-2800.';
          console.error('rsvp submit error:', err);
        });
      });

      // Real-time error clearing
      ['f-first','f-last','f-email','f-phone'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input', function () {
          var field = el.closest('.field');
          if (field) field.classList.remove('error');
        });
      });
    }
  })();
</script>
