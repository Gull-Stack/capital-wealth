<script>
(function () {
  'use strict';

  function killChrome() {
    ['.cwh-shell', '#cwhShell', 'header.cwh-shell', '.finpay-header', 'header.finpay-header',
     '.finpay-nav-wrapper', '.finpay-footer', 'footer.finpay-footer'].forEach(function (sel) {
      document.querySelectorAll(sel).forEach(function (el) {
        if (el.closest('.lp-ty-header') || el.closest('.lp-ty-footer')) return;
        if (el.classList.contains('lp-ty-header') || el.classList.contains('lp-ty-footer')) return;
        el.style.display = 'none';
        if (el.parentNode) el.parentNode.removeChild(el);
      });
    });
  }

  function getAttribution() {
    var params = new URLSearchParams(window.location.search);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
    var attr = {};
    keys.forEach(function (k) { var v = params.get(k); if (v) attr[k] = v; });
    if (!attr.utm_source) {
      ['cw_lp_federal_review_attrib', 'cw_lp_10things_attrib'].forEach(function (storageKey) {
        try {
          var stored = sessionStorage.getItem(storageKey);
          if (stored) {
            var parsed = JSON.parse(stored) || {};
            keys.forEach(function (k) { if (parsed[k] && !attr[k]) attr[k] = parsed[k]; });
          }
        } catch (e) {}
      });
    }
    return attr;
  }

  function showSource(attr) {
    var src = attr.utm_source || (attr.fbclid ? 'facebook' : (attr.gclid ? 'google' : ''));
    if (!src) return;
    var map = {
      'facebook': 'Facebook', 'fb': 'Facebook', 'meta': 'Facebook',
      'google': 'Google', 'google_ads': 'Google Ads', 'googleads': 'Google Ads',
      'reddit': 'Reddit', 'email': 'an email', 'newsletter': 'our newsletter',
      'linkedin': 'LinkedIn', 'organic': 'search', 'direct': 'direct'
    };
    var display = map[src.toLowerCase()] || src;
    var el = document.getElementById('lp-ty-source');
    if (el && display) {
      el.textContent = 'Thanks for visiting from ' + display + '.';
      el.classList.add('is-visible');
    }
  }

  function fireConversions(attr) {
    if (typeof gtag === 'function') {
      gtag('event', 'conversion_review_ty', {
        event_category: 'conversion',
        event_label: 'federal_review_booking',
        value: 50,
        currency: 'USD',
        utm_source: attr.utm_source || '',
        utm_medium: attr.utm_medium || '',
        utm_campaign: attr.utm_campaign || '',
        utm_content: attr.utm_content || '',
        utm_term: attr.utm_term || ''
      });
      // Google Ads conversion — REPLACE 'AW-18091003527/REVIEW_LABEL'
      gtag('event', 'conversion', {
        send_to: 'AW-18091003527/REVIEW_LABEL',
        value: 50,
        currency: 'USD'
      });
    }

    if (typeof fbq === 'function') {
      fbq('track', 'Schedule', {
        content_name: 'federal_review_booking',
        content_category: 'Federal Benefits',
        value: 50,
        currency: 'USD'
      });
    }

    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'lp_ty_view',
      ty_page: 'federal_review',
      utm_source: attr.utm_source || '',
      utm_medium: attr.utm_medium || '',
      utm_campaign: attr.utm_campaign || '',
      value: 50,
      currency: 'USD'
    });

    // Reddit Pixel placeholder
    // if (typeof rdt === 'function') { rdt('track', 'Lead'); }
  }

  function init() {
    killChrome();
    var attr = getAttribution();
    showSource(attr);
    fireConversions(attr);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  setTimeout(killChrome, 250);
  setTimeout(killChrome, 1500);
})();
</script>
