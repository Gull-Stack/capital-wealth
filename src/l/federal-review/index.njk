{# ═══════════ JS ═══════════ #}
<script>
(function () {
  'use strict';

  function killChrome() {
    ['.cwh-shell', '#cwhShell', 'header.cwh-shell', '.finpay-header', 'header.finpay-header',
     '.finpay-nav-wrapper', '.finpay-footer', 'footer.finpay-footer'].forEach(function (sel) {
      document.querySelectorAll(sel).forEach(function (el) {
        if (el.closest('.lp-mini-header') || el.closest('.lp-mini-footer')) return;
        if (el.classList.contains('lp-mini-header') || el.classList.contains('lp-mini-footer')) return;
        el.style.display = 'none';
        if (el.parentNode) el.parentNode.removeChild(el);
      });
    });
  }

  var STORAGE_KEY = 'cw_lp_federal_review_attrib';
  function captureAttribution() {
    var params = new URLSearchParams(window.location.search);
    var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
    var captured = {};
    try { var s = sessionStorage.getItem(STORAGE_KEY); if (s) captured = JSON.parse(s) || {}; } catch (e) {}
    keys.forEach(function (k) { var v = params.get(k); if (v) captured[k] = v; });
    if (!captured.referrer && document.referrer) captured.referrer = document.referrer;
    try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(captured)); } catch (e) {}
    keys.forEach(function (k) {
      var el = document.getElementById('lp-fr-' + k.replace('_', '-'));
      if (el && captured[k]) el.value = captured[k];
    });
    var refEl = document.getElementById('lp-fr-referrer');
    if (refEl) refEl.value = captured.referrer || '';
  }

  function trackPageView() {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'lp_federal_review_view' });
    if (typeof fbq === 'function') {
      fbq('track', 'ViewContent', { content_name: 'lp_federal_review', content_category: 'Federal Benefits' });
    }
  }

  function initForm() {
    var form = document.getElementById('lp-fr-form');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var honey = document.getElementById('lp-fr-website');
      if (honey && honey.value) return;
      if (!form.checkValidity()) { form.reportValidity(); return; }

      var submitBtn = document.getElementById('lp-fr-submit');
      var originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      var formData = new FormData(form);
      var data = {};
      formData.forEach(function (v, k) { data[k] = v; });

      fetch('/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function (r) { return r.json(); })
      .then(function (result) {
        if (result.success) {
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', { event_category: 'lead', event_label: 'federal_review_booking', value: 50 });
          }
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'lp_federal_review_form_submit', form: 'review' });
          if (typeof fbq === 'function') {
            fbq('track', 'Lead', {
              content_name: 'lp_federal_review',
              content_category: 'Federal Benefits',
              value: 50,
              currency: 'USD'
            });
          }
          var formContent = form.closest('.lp-fr-form-card').querySelector('.lp-fr-form-content');
          var success = document.getElementById('lp-fr-success');
          if (formContent) formContent.style.display = 'none';
          if (success) success.classList.add('is-visible');
          setTimeout(function () {
            var utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
            var utmQs = utmKeys
              .map(function (k) {
                var el = document.getElementById('lp-fr-' + k.replace('_', '-'));
                return (el && el.value) ? encodeURIComponent(k) + '=' + encodeURIComponent(el.value) : null;
              })
              .filter(Boolean).join('&');
            window.location.href = '/l/federal-review/ty/' + (utmQs ? '?' + utmQs : '');
          }, 1500);
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          alert(result.error || 'Something went wrong. Please try again, or call us at (801) 210-2800.');
        }
      })
      .catch(function (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        console.error('Form submit error:', err);
        alert('Something went wrong. Please try again, or call us at (801) 210-2800.');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      killChrome();
      captureAttribution();
      trackPageView();
      initForm();
    });
  } else {
    killChrome();
    captureAttribution();
    trackPageView();
    initForm();
  }
  setTimeout(killChrome, 250);
  setTimeout(killChrome, 1500);
})();
</script>
