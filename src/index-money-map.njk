  /* KEYFRAMES — Ken Burns + chaos drift + reveals */
  @keyframes kenburns {
    0%   { transform: scale(1.08) translate(0%, 0%); }
    50%  { transform: scale(1.14) translate(-1.5%, -1%); }
    100% { transform: scale(1.08) translate(0%, 0%); }
  }
  @keyframes chaos-drift-1 {
    0%, 100% { transform: rotate(-4deg) translate(0, 0); }
    20%      { transform: rotate(-5.2deg) translate(-3px, 2px); }
    40%      { transform: rotate(-3.1deg) translate(4px, -1px); }
    60%      { transform: rotate(-4.6deg) translate(-2px, 3px); }
    80%      { transform: rotate(-3.6deg) translate(2px, -2px); }
  }
  @keyframes chaos-drift-2 {
    0%, 100% { transform: rotate(2.5deg) translate(0, 0); }
    25%      { transform: rotate(3.8deg) translate(3px, -2px); }
    50%      { transform: rotate(1.2deg) translate(-4px, 3px); }
    75%      { transform: rotate(3.1deg) translate(2px, 2px); }
  }
  @keyframes chaos-drift-3 {
    0%, 100% { transform: rotate(-1.5deg) translate(0, 0); }
    30%      { transform: rotate(-0.4deg) translate(-3px, -3px); }
    60%      { transform: rotate(-2.8deg) translate(3px, 2px); }
  }
  @keyframes chaos-drift-4 {
    0%, 100% { transform: rotate(3deg) translate(0, 0); }
    30%      { transform: rotate(4.4deg) translate(-2px, 3px); }
    70%      { transform: rotate(1.8deg) translate(3px, -2px); }
  }
  @keyframes chaos-drift-5 {
    0%, 100% { transform: rotate(1deg) translate(0, 0); }
    40%      { transform: rotate(2.6deg) translate(-3px, -1px); }
    80%      { transform: rotate(-0.4deg) translate(2px, 3px); }
  }
  @keyframes chaos-drift-6 {
    0%, 100% { transform: rotate(-3deg) translate(0, 0); }
    35%      { transform: rotate(-4.5deg) translate(2px, 2px); }
    70%      { transform: rotate(-1.6deg) translate(-3px, -3px); }
  }
  @keyframes slide-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes row-in {
    from { opacity: 0; transform: translateX(-10px); }
    to   { opacity: 1; transform: translateX(0); }
