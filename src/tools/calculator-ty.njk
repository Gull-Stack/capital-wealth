  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 24px; font-size: 36px; font-weight: 700;
  box-shadow: 0 12px 32px rgba(179, 25, 66, 0.4);
}
.lp-ty-hero h1 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 2.3rem; font-weight: 700; line-height: 1.15;
  margin: 0 0 16px; color: var(--cw-white); letter-spacing: -0.01em;
}
.lp-ty-hero-sub {
  font-size: 1.1rem; line-height: 1.6;
  color: rgba(255, 255, 255, 0.92); margin: 0;
}
.lp-ty-source {
  display: none;
  margin-top: 24px;
  padding: 10px 18px;
