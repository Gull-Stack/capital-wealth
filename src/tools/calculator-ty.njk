  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 24px;
  font-size: 0.88rem;
  color: rgba(255, 255, 255, 0.85);
}
.lp-ty-source.is-visible { display: inline-block; }

.lp-ty-meantime {
  background: var(--cw-white); padding: 64px 24px;
}
.lp-ty-meantime-inner { max-width: 720px; margin: 0 auto; text-align: center; }
.lp-ty-meantime h2 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 1.9rem; font-weight: 700; color: var(--cw-fed-blue);
  margin: 0 0 16px; line-height: 1.25;
}
.lp-ty-meantime p {
  color: var(--cw-muted); font-size: 1.02rem;
  line-height: 1.7; margin: 0 auto 32px; max-width: 600px;
}
.lp-ty-meantime-links {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 16px; max-width: 600px; margin: 0 auto;
}
.lp-ty-meantime-card {
  background: var(--cw-bg-subtle); border-radius: 12px;
  padding: 20px; text-decoration: none; color: inherit;
  border-left: 4px solid var(--cw-fed-red);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  text-align: left;
}
.lp-ty-meantime-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(10, 49, 97, 0.08);
}
.lp-ty-meantime-card h3 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 1.05rem; font-weight: 700;
  color: var(--cw-fed-blue); margin: 0 0 6px; line-height: 1.3;
}
.lp-ty-meantime-card p {
  margin: 0; font-size: 0.88rem; color: var(--cw-muted); line-height: 1.5;
}

.lp-ty-upsell {
  background: var(--cw-fed-blue); color: var(--cw-white);
  padding: 56px 24px; text-align: center;
}
.lp-ty-upsell-inner { max-width: 680px; margin: 0 auto; }
.lp-ty-upsell h2 {
  font-family: var(--font-serif-display, Georgia, serif);
  font-size: 1.6rem; font-weight: 700;
  margin: 0 0 12px; color: var(--cw-white); line-height: 1.25;
}
.lp-ty-upsell p {
  color: rgba(255, 255, 255, 0.88); font-size: 1rem;
  line-height: 1.6; margin: 0 0 24px;
}
.lp-ty-upsell a {
  display: inline-block; background: var(--cw-fed-red); color: var(--cw-white);
  padding: 14px 28px; border-radius: 8px;
  font-weight: 700; font-size: 0.98rem; text-decoration: none;
  transition: background 0.2s ease, transform 0.2s ease;
}
.lp-ty-upsell a:hover { background: var(--cw-fed-red-dark); transform: translateY(-1px); }

.lp-ty-footer {
  background: var(--cw-fed-blue-dark); color: rgba(255, 255, 255, 0.75);
  padding: 32px 24px 40px; font-size: 0.82rem; line-height: 1.6; text-align: center;
}
.lp-ty-footer-inner { max-width: 900px; margin: 0 auto; }
.lp-ty-footer a {
  color: rgba(255, 255, 255, 0.9);
  text-decoration: underline; text-decoration-color: rgba(255, 255, 255, 0.3);
}
.lp-ty-footer-links {
  margin-top: 14px; display: flex; gap: 18px;
  justify-content: center; flex-wrap: wrap; font-size: 0.8rem;
}

@media (max-width: 560px) {
  .lp-ty-hero { padding: 56px 18px; }
  .lp-ty-hero h1 { font-size: 1.65rem; }
  .lp-ty-meantime, .lp-ty-upsell { padding: 48px 18px; }
  .lp-ty-meantime-links { grid-template-columns: 1fr; }
  .lp-ty-meantime h2 { font-size: 1.45rem; }
  .lp-ty-upsell h2 { font-size: 1.35rem; }
}
</style>

