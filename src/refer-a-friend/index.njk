{# ═══ REFERRAL FORM ═══ #}
<section id="refer-form" class="contact-hero-section" style="background: #f8f9fa; padding: 3.4rem 2rem;">
    <div style="max-width: 700px; margin: 0 auto;">
        <div class="contact-form-card">
            <h2 class="contact-form-title">Refer a Friend</h2>
            <p class="contact-form-subtitle">Fill out the form below and we'll reach out to schedule their complimentary consultation.</p>

            <form id="refer-form-el">
                <div class="contact-form-grid">
                    <div style="margin-bottom: 1.25rem;">
                        <label for="your_name" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Your Name *</label>
                        <input type="text" id="your_name" name="your_name" required style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body);">
                    </div>
                    <div style="margin-bottom: 1.25rem;">
                        <label for="your_email" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Your Email *</label>
                        <input type="email" id="your_email" name="your_email" required style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body);">
                    </div>
                </div>

                <div style="border-top: 1px solid rgba(0,0,0,0.08); margin: 1.5rem 0; padding-top: 1.5rem;">
                    <p style="font-weight: 600; color: var(--navy); margin-bottom: 1rem;">Person You're Referring</p>
                </div>

                <div class="contact-form-grid">
                    <div style="margin-bottom: 1.25rem;">
                        <label for="ref_name" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Their Name *</label>
                        <input type="text" id="ref_name" name="ref_name" required style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body);">
                    </div>
                    <div style="margin-bottom: 1.25rem;">
                        <label for="ref_phone" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Their Phone *</label>
                        <input type="tel" id="ref_phone" name="ref_phone" required style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body);">
                    </div>
                </div>

                <div class="contact-form-grid">
                    <div style="margin-bottom: 1.25rem;">
                        <label for="ref_email" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Their Email</label>
                        <input type="email" id="ref_email" name="ref_email" style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body);">
                    </div>
                    <div style="margin-bottom: 1.25rem;">
                        <label for="ref_relationship" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Relationship</label>
                        <select id="ref_relationship" name="ref_relationship" style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body);">
                            <option value="">Please select</option>
                            <option value="Family">Family Member</option>
                            <option value="Friend">Friend</option>
                            <option value="Colleague">Colleague</option>
                            <option value="Neighbor">Neighbor</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label for="ref_notes" style="display: block; margin-bottom: 0.5rem; color: var(--navy); font-weight: 500; font-size: 0.95rem;">Anything we should know?</label>
                    <textarea id="ref_notes" name="ref_notes" rows="3" style="width: 100%; padding: 0.85rem; border: none; border-radius: 12px; background: #f8f9fb; color: #16253C; font-size: 1rem; font-family: var(--font-body); resize: vertical;" placeholder="e.g., They're retiring next year, interested in federal benefits, etc."></textarea>
                </div>

                <div style="display:none;"><input type="text" name="website" tabindex="-1" autocomplete="off"></div>

                <button type="submit" id="refer-submit-btn" class="cwh-glass-btn cwh-primary" style="width: 100%; justify-content: center;">SUBMIT REFERRAL <span>→</span></button>
                <div id="refer-form-status" style="margin-top: 12px; text-align: center; font-weight: 500;"></div>
            </form>

            <script>
            document.getElementById('refer-form-el').addEventListener('submit', async function(e) {
                e.preventDefault();
                var btn = document.getElementById('refer-submit-btn');
                var status = document.getElementById('refer-form-status');
                if (this.querySelector('[name="website"]').value) return;
                btn.disabled = true;
                btn.innerHTML = 'SENDING...';
                status.textContent = '';
                try {
                    var res = await fetch('/api/submit-lead', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            name: document.getElementById('ref_name').value,
                            email: document.getElementById('ref_email').value || 'no-email@referral.capitalwealth.com',
                            phone: document.getElementById('ref_phone').value,
                            questions: 'REFERRAL from ' + document.getElementById('your_name').value + ' (' + document.getElementById('your_email').value + '). Relationship: ' + (document.getElementById('ref_relationship').value || 'Not specified') + '. Notes: ' + (document.getElementById('ref_notes').value || 'None'),
                            lead_type: 'client-ambassador-referral',
                            lead_source: 'Client Ambassador Referral',
                            campaign_id: '701VS00000a0wTOYAY',
                            submitted_from: '/refer-a-friend/',
                            utm_source: 'referral',
                            utm_medium: 'client_ambassador',
                            utm_campaign: 'ambassador_club'
                        })
                    });
                    var data = await res.json();
                    if (res.ok) {
                        status.style.color = '#2d8a4e';
                        status.textContent = 'Thank you! Redirecting you to schedule a consultation...';
                        this.reset();
                        if (typeof gtag === 'function') {
                            gtag('event', 'generate_lead', { event_category: 'conversion', event_label: 'referral', value: 1 });
                        }
                        setTimeout(function() {
                            window.location.href = '/thank-you/';
                        }, 1500);
                    } else {
                        status.style.color = '#c0392b';
                        status.textContent = data.error || 'Something went wrong.';
                    }
                } catch (err) {
                    status.style.color = '#c0392b';
                    status.textContent = 'Network error. Please call us at 801.210.2800.';
                }
                btn.disabled = false;
                btn.innerHTML = 'SUBMIT REFERRAL <span>→</span>';
            });
            </script>

            <p class="contact-form-disclaimer">Your referral's information is kept confidential. We'll reach out to schedule a complimentary consultation and will mention your name as the person who introduced us.</p>
        </div>
    </div>
</section>
