{
  "buildCommand": "npm run build",
  "outputDirectory": "_site",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/book", "destination": "https://www.retirerightbook.com/", "permanent": true },
    { "source": "/book/", "destination": "https://www.retirerightbook.com/", "permanent": true },
    { "source": "/federal", "destination": "/services/federal-benefits/", "permanent": true },
    { "source": "/federal/", "destination": "/services/federal-benefits/", "permanent": true },
    { "source": "/services/federal-benefits/fers", "destination": "/services/federal-benefits/fers-retirement/", "permanent": true },
    { "source": "/services/federal-benefits/fers/", "destination": "/services/federal-benefits/fers-retirement/", "permanent": true },
    { "source": "/services/federal-benefits/medicare-irmaa", "destination": "/services/medicare-irmaa/", "permanent": true },
    { "source": "/services/federal-benefits/medicare-irmaa/", "destination": "/services/medicare-irmaa/", "permanent": true },
    { "source": "/services/retirement/401k-rollover", "destination": "/services/401k-ira-rollover/", "permanent": true },
    { "source": "/services/retirement/401k-rollover/", "destination": "/services/401k-ira-rollover/", "permanent": true }
  ]
}
