{
  "buildCommand": "npm run build",
  "outputDirectory": "_site",
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "retireutah.com" }], "destination": "https://www.capitalwealth.com/l/retire-utah/", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.retireutah.com" }], "destination": "https://www.capitalwealth.com/l/retire-utah/", "permanent": true },
    { "source": "/book", "destination": "https://www.retirerightbook.com/?utm_source=capitalwealth&utm_medium=website&utm_campaign=book", "permanent": false },
    { "source": "/book/", "destination": "https://www.retirerightbook.com/?utm_source=capitalwealth&utm_medium=website&utm_campaign=book", "permanent": false },
    { "source": "/federal", "destination": "/services/federal-benefits/", "permanent": true },
    { "source": "/federal/", "destination": "/services/federal-benefits/", "permanent": true },
    { "source": "/refer", "destination": "/refer-a-friend/", "permanent": true },
    { "source": "/refer/", "destination": "/refer-a-friend/", "permanent": true },
    { "source": "/federal-guide", "destination": "/services/federal-benefits/", "permanent": false },
    { "source": "/federal-guide/", "destination": "/services/federal-benefits/", "permanent": false },
    { "source": "/services/federal-benefits/fers", "destination": "/services/federal-benefits/fers-retirement/", "permanent": true },
    { "source": "/services/federal-benefits/fers/", "destination": "/services/federal-benefits/fers-retirement/", "permanent": true },
    { "source": "/services/federal-benefits/medicare-irmaa", "destination": "/services/medicare-irmaa/", "permanent": true },
    { "source": "/services/federal-benefits/medicare-irmaa/", "destination": "/services/medicare-irmaa/", "permanent": true },
    { "source": "/services/retirement/401k-rollover", "destination": "/services/401k-ira-rollover/", "permanent": true },
    { "source": "/services/retirement/401k-rollover/", "destination": "/services/401k-ira-rollover/", "permanent": true },
    { "source": "/blog/fers-coordination-strategies", "destination": "/services/federal-benefits/fers-retirement/", "permanent": true },
    { "source": "/blog/fers-coordination-strategies/", "destination": "/services/federal-benefits/fers-retirement/", "permanent": true },
    { "source": "/blog/tsp-withdrawal-strategies", "destination": "/services/federal-benefits/tsp-planning/", "permanent": true },
    { "source": "/blog/tsp-withdrawal-strategies/", "destination": "/services/federal-benefits/tsp-planning/", "permanent": true },
    { "source": "/blog/healthcare-planning-retirement", "destination": "/retirement-planning/", "permanent": true },
    { "source": "/blog/healthcare-planning-retirement/", "destination": "/retirement-planning/", "permanent": true },
    { "source": "/blog/social-security-optimization-utah", "destination": "/services/social-security/", "permanent": true },
    { "source": "/blog/social-security-optimization-utah/", "destination": "/services/social-security/", "permanent": true },
    { "source": "/federal-benefits-workshop", "destination": "/l/federal-benefits-workshop/", "permanent": true },
    { "source": "/federal-benefits-workshop/", "destination": "/l/federal-benefits-workshop/", "permanent": true }
  ]
}
